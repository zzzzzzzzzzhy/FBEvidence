<!-- 1. 完整的主页面 - src/main/resources/static/index.html -->
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>区块链存证系统</title>
    <link href="https://cdn.bootcdn.net/ajax/libs/element-ui/2.15.14/theme-chalk/index.css" rel="stylesheet">
    <link href="/static/css/style.css" rel="stylesheet">
    <link href="/static/css/text-upload.css" rel="stylesheet">
    <!-- <link rel="icon" href="/static/favicon.ico" type="image/x-icon"> -->
    <link rel="manifest" href="/static/manifest.json">
    <meta name="theme-color" content="#409eff">
</head>
<body>
<div id="app">
    <el-container>
        <!-- 头部导航 -->
        <el-header class="header">
            <div class="header-left">
                <div class="logo">
                    <img src="/static/images/logo.svg" alt="Logo" class="logo-img">
                    <h2>区块链存证系统</h2>
                </div>
            </div>
            <div class="header-right" v-if="userInfo">
                <el-menu
                        mode="horizontal"
                        :default-active="activeIndex"
                        class="nav-menu"
                        @select="handleMenuSelect">
                    <el-menu-item index="1">
                        <i class="el-icon-upload"></i>
                        文件存证
                    </el-menu-item>
                    <el-menu-item index="2">
                        <i class="el-icon-document"></i>
                        代码存证
                    </el-menu-item>
                    <el-menu-item index="3">
                        <i class="el-icon-search"></i>
                        查询验证
                    </el-menu-item>
                    <el-menu-item index="4">
                        <i class="el-icon-s-data"></i>
                        区块链信息
                    </el-menu-item>
                </el-menu>
                <el-dropdown class="user-dropdown">
                        <span class="el-dropdown-link">
                            <i class="el-icon-user-solid"></i>
                            {{ userInfo.realName || userInfo.username }}
                            <i class="el-icon-arrow-down el-icon--right"></i>
                        </span>
                    <el-dropdown-menu slot="dropdown">
                        <el-dropdown-item @click.native="showUserInfo">个人信息</el-dropdown-item>
                        <el-dropdown-item divided @click.native="logout">退出登录</el-dropdown-item>
                    </el-dropdown-menu>
                </el-dropdown>
            </div>
        </el-header>


        <!-- 主体内容 -->
        <el-main v-if="!userInfo" class="login-main">
            <!-- 登录页面 -->
            <div class="login-container">
                <div class="login-background"></div>
                <el-card class="login-card" shadow="always">
                    <div slot="header" class="login-header">
                        <img src="/static/images/login-logo.svg" alt="Login Logo" class="login-logo">
                        <h3>区块链存证系统</h3>
                        <p>基于FISCO BCOS的数据存证平台</p>
                    </div>
                    <el-form :model="loginForm" :rules="loginRules" ref="loginForm" class="login-form">
                        <el-form-item prop="username">
                            <el-input
                                    v-model="loginForm.username"
                                    placeholder="请输入用户名"
                                    prefix-icon="el-icon-user"
                                    size="large"
                                    @keyup.enter.native="handleLogin">
                            </el-input>
                        </el-form-item>
                        <el-form-item prop="password">
                            <el-input
                                    v-model="loginForm.password"
                                    type="password"
                                    placeholder="请输入密码"
                                    prefix-icon="el-icon-lock"
                                    size="large"
                                    show-password
                                    @keyup.enter.native="handleLogin">
                            </el-input>
                        </el-form-item>
                        <el-form-item>
                            <el-button
                                    type="primary"
                                    :loading="loginLoading"
                                    @click="handleLogin"
                                    size="large"
                                    class="login-button">
                                <i class="el-icon-right"></i>
                                立即登录
                            </el-button>
                        </el-form-item>
                        <el-form-item>
                            <el-button
                                    type="info"
                                    size="large"
                                    @click="showRegister = true"
                                    class="register-button">
                                <i class="el-icon-user-solid"></i>
                                用户注册
                            </el-button>
                        </el-form-item>
                    </el-form>
                    <div class="login-tips">
                        <el-alert
                                title="测试账号信息"
                                type="info"
                                :closable="false"
                                show-icon>
                            <div style="margin-bottom: 8px;">
                                <span>管理员：admin / 123123</span>
                                <el-button 
                                    type="text" 
                                    size="mini" 
                                    @click="fillTestAccount('admin')"
                                    style="margin-left: 10px; padding: 0; color: #409eff;">
                                    快速填入
                                </el-button>
                            </div>
                            <!--<div style="margin-bottom: 10px;">
                                <span>普通用户：user1 / password123</span>
                                <el-button 
                                    type="text" 
                                    size="mini" 
                                    @click="fillTestAccount('user1')"
                                    style="margin-left: 10px; padding: 0; color: #409eff;">
                                    快速填入
                                </el-button>
                            </div>-->
                            <div style="color: #909399; font-size: 12px;">
                                <i class="el-icon-info"></i> 点击"快速填入"可自动填充登录信息，或者点击上方按钮注册新账号
                            </div>
                        </el-alert>
                    </div>
                    <div class="login-extra-info" style="margin-top: 20px; text-align: center;">
                        <el-divider>其他选项</el-divider>
                        <p style="color: #909399; font-size: 14px;">
                            <i class="el-icon-info"></i> 
                            如果您是新用户，请联系系统管理员获取账号
                        </p>
                        <p style="color: #909399; font-size: 14px;">
                            <i class="el-icon-question"></i> 
                            忘记密码？请联系管理员重置
                        </p>
                    </div>
                </el-card>
            </div>
        </el-main>

        <!-- 用户注册对话框 -->
        <el-dialog 
            title="用户注册" 
            :visible.sync="showRegister" 
            width="500px" 
            :before-close="handleRegisterClose"
            center>
            <el-form :model="registerForm" :rules="registerRules" ref="registerForm" label-width="100px">
                <el-form-item label="用户名" prop="username">
                    <el-input 
                        v-model="registerForm.username" 
                        placeholder="请输入用户名（支持字母、数字、下划线、中划线和中文）"
                        prefix-icon="el-icon-user"
                        maxlength="30"
                        show-word-limit>
                    </el-input>
                    <div style="font-size: 12px; color: #909399; margin-top: 5px;">
                        <i class="el-icon-info"></i> 用户名将用于生成您的唯一DID标识
                    </div>
                </el-form-item>

                <el-form-item label="真实姓名" prop="realName">
                    <el-input 
                        v-model="registerForm.realName" 
                        placeholder="请输入您的真实姓名"
                        prefix-icon="el-icon-s-custom"
                        maxlength="30"
                        show-word-limit>
                    </el-input>
                </el-form-item>

                <el-form-item label="邮箱" prop="email">
                    <el-input 
                        v-model="registerForm.email" 
                        placeholder="请输入邮箱地址（可选）"
                        prefix-icon="el-icon-message"
                        type="email">
                    </el-input>
                    <div style="font-size: 12px; color: #909399; margin-top: 5px;">
                        <i class="el-icon-info"></i> 邮箱地址将参与DID生成，确保唯一性
                    </div>
                </el-form-item>

                <el-form-item label="密码" prop="password">
                    <el-input 
                        v-model="registerForm.password" 
                        type="password"
                        placeholder="请输入密码（至少6位字符）"
                        prefix-icon="el-icon-lock"
                        show-password
                        maxlength="20">
                    </el-input>
                </el-form-item>

                <el-form-item label="确认密码" prop="confirmPassword">
                    <el-input 
                        v-model="registerForm.confirmPassword" 
                        type="password"
                        placeholder="请再次输入密码"
                        prefix-icon="el-icon-lock"
                        show-password
                        maxlength="20">
                    </el-input>
                </el-form-item>

                <el-alert
                    title="关于DID标识"
                    type="info"
                    :closable="false"
                    show-icon
                    style="margin-bottom: 20px;">
                    <p style="margin: 0; font-size: 14px;">
                        注册成功后，系统将为您生成唯一的DID（去中心化标识符），格式如：<br/>
                        <code style="background: #f5f7fa; padding: 2px 4px; border-radius: 3px;">did:evidence:a1b2c3d4e5f6g7h8</code><br/>
                        您可以使用用户名或DID进行登录
                    </p>
                </el-alert>
            </el-form>

            <div slot="footer" class="dialog-footer">
                <el-button @click="handleRegisterClose">取 消</el-button>
                <el-button 
                    type="primary" 
                    :loading="registerLoading"
                    @click="handleRegister">
                    <i class="el-icon-check"></i>
                    立即注册
                </el-button>
            </div>
        </el-dialog>

        <el-main v-if="userInfo" class="main-content">
            <!-- 页面快速导航 -->
            <div class="page-navigation" style="background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1); margin-bottom: 16px; padding: 16px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div class="current-module">
                        <el-tag size="medium" :type="activeTab === 'upload' ? 'primary' : 'info'">
                            <i class="el-icon-location-outline"></i>
                            {{ getModuleName(activeTab) }}
                        </el-tag>
                    </div>
                    <div class="module-quick-nav">
                        <el-button-group>
                            <el-button size="small" icon="el-icon-upload" @click="quickSwitchTab('upload')" :type="activeTab === 'upload' ? 'primary' : 'default'">文件存证</el-button>
                            <el-button size="small" icon="el-icon-document" @click="quickSwitchTab('code')" :type="activeTab === 'code' ? 'primary' : 'default'">代码存证</el-button>
                            <el-button size="small" icon="el-icon-search" @click="quickSwitchTab('query')" :type="activeTab === 'query' ? 'primary' : 'default'">查询验证</el-button>
                            <el-button size="small" icon="el-icon-s-data" @click="quickSwitchTab('blockchain')" :type="activeTab === 'blockchain' ? 'primary' : 'default'">区块链信息</el-button>
                        </el-button-group>
                    </div>
                </div>
            </div>
            <!-- Tab切换内容 -->
            <el-tabs v-model="activeTab" type="card" class="main-tabs" :key="'main-tabs-' + activeTab">
                <!-- 文件存证Tab -->
                <el-tab-pane label="文件存证" name="upload">
                    <div class="tab-content">
                        <!-- 文件存证管理导航 -->
                        <el-card class="management-nav-card" shadow="never" style="margin-bottom: 20px;">
                            <div class="management-nav" style="display: flex; justify-content: space-between; align-items: center;">
                                <el-radio-group v-model="fileEvidenceActiveView" @change="handleFileEvidenceViewChange">
                                    <el-radio-button label="upload">文件上传</el-radio-button>
                                    <el-radio-button label="groups">分组管理</el-radio-button>
                                    <el-radio-button label="projects">项目管理</el-radio-button>
                                    <el-radio-button label="files">文件列表</el-radio-button>
                                    <el-radio-button label="logs">操作日志</el-radio-button>
                                </el-radio-group>
                                <div class="nav-actions" style="display: flex; align-items: center; gap: 15px;">
                                    <div class="action-buttons">
                                        <el-button v-if="fileEvidenceActiveView === 'groups'" type="primary" size="small" icon="el-icon-plus" @click="showCreateGroupDialog">新建分组</el-button>
                                        <el-button v-if="fileEvidenceActiveView === 'projects'" type="primary" size="small" icon="el-icon-plus" @click="showCreateProjectDialog">新建项目</el-button>
                                    </div>
                                    <div class="quick-nav-buttons">
                                        <el-tooltip content="快速切换到其他模块" placement="top">
                                            <el-button-group>
                                                <el-button size="small" icon="el-icon-document" @click="quickSwitchTab('code')" :type="activeTab === 'code' ? 'primary' : 'default'">代码存证</el-button>
                                                <el-button size="small" icon="el-icon-search" @click="quickSwitchTab('query')" :type="activeTab === 'query' ? 'primary' : 'default'">查询验证</el-button>
                                                <el-button size="small" icon="el-icon-s-data" @click="quickSwitchTab('blockchain')" :type="activeTab === 'blockchain' ? 'primary' : 'default'">区块链信息</el-button>
                                            </el-button-group>
                                        </el-tooltip>
                                    </div>
                                </div>
                            </div>
                        </el-card>

                        <!-- 文件上传视图 -->
                        <div v-if="fileEvidenceActiveView === 'upload'">
                            <el-row :gutter="20">
                                <!-- 项目选择和文件上传区域 -->
                                <el-col :span="16">
                                    <el-card class="upload-card" shadow="hover">
                                        <div slot="header">
                                            <span><i class="el-icon-upload2"></i> 文件存证上传</span>
                                            <div class="card-header-right">
                                                <el-tag size="small">支持单文件/批量上传</el-tag>
                                            </div>
                                        </div>

                                        <!-- 项目选择 -->
                                        <div class="project-selection">
                                            <el-form :inline="true" size="small">
                                                <el-form-item label="目标分组：">
                                                    <el-select v-model="selectedGroupId" placeholder="请选择分组" @change="onGroupChange" style="width: 200px;">
                                                        <el-option v-for="group in userGroups" :key="group.id" :label="group.groupName" :value="group.id">
                                                            <span style="float: left">{{ group.groupName }}</span>
                                                            <span style="float: right; color: #8492a6; font-size: 13px">{{ group.groupCode }}</span>
                                                        </el-option>
                                                    </el-select>
                                                </el-form-item>
                                                <el-form-item label="目标项目：">
                                                    <el-select v-model="selectedProjectId" placeholder="请选择项目" :disabled="!selectedGroupId" style="width: 200px;">
                                                        <el-option v-for="project in currentProjects" :key="project.id" :label="project.projectName" :value="project.id">
                                                            <span style="float: left">{{ project.projectName }}</span>
                                                            <span style="float: right; color: #8492a6; font-size: 13px">{{ project.projectCode }}</span>
                                                        </el-option>
                                                    </el-select>
                                                </el-form-item>
                                            </el-form>
                                        </div>

                                        <!-- 单文件上传 -->
                                        <div class="single-upload-section">
                                            <h4><i class="el-icon-upload"></i> 单文件上传</h4>
                                            <el-upload
                                                    class="upload-dragger"
                                                    :action="fileEvidenceUploadAction"
                                                    :headers="uploadHeaders"
                                                    :data="fileEvidenceUploadData"
                                                    :on-success="handleFileEvidenceUploadSuccess"
                                                    :on-error="handleFileEvidenceUploadError"
                                                    :before-upload="beforeFileEvidenceUpload"
                                                    :file-list="fileEvidenceFileList"
                                                    drag
                                                    :limit="1"
                                                    :auto-upload="false"
                                                    ref="fileEvidenceUpload">
                                                <i class="el-icon-upload"></i>
                                                <div class="el-upload__text">将文件拖到此处，或<em>点击上传</em></div>
                                                <div class="el-upload__tip" slot="tip">
                                                    <div>支持多种格式，单个文件不超过100MB</div>
                                                </div>
                                            </el-upload>
                                        </div>

                                        <!-- 批量上传 -->
                                        <div class="batch-upload-section" style="margin-top: 30px;">
                                            <el-divider>
                                                <el-tag type="info">批量上传</el-tag>
                                            </el-divider>
                                            <h4><i class="el-icon-folder-opened"></i> 批量文件上传</h4>
                                            <el-form :inline="true" size="small" style="margin-bottom: 15px;">
                                                <el-form-item label="提交信息：">
                                                    <el-input v-model="batchCommitMessage" placeholder="请输入批量上传的提交信息" style="width: 300px;"></el-input>
                                                </el-form-item>
                                            </el-form>
                                            <el-upload
                                                    class="upload-dragger"
                                                    :action="fileEvidenceBatchUploadAction"
                                                    :headers="uploadHeaders"
                                                    :data="fileEvidenceBatchUploadData"
                                                    :on-success="handleFileEvidenceBatchUploadSuccess"
                                                    :on-error="handleFileEvidenceBatchUploadError"
                                                    :before-upload="beforeFileEvidenceBatchUpload"
                                                    :file-list="fileEvidenceBatchFileList"
                                                    drag
                                                    multiple
                                                    :limit="20"
                                                    :auto-upload="false"
                                                    ref="fileEvidenceBatchUpload">
                                                <i class="el-icon-folder-opened"></i>
                                                <div class="el-upload__text">批量上传：将多个文件拖到此处</div>
                                                <div class="el-upload__tip" slot="tip">
                                                    <div>最多支持20个文件同时上传</div>
                                                </div>
                                            </el-upload>
                                        </div>

                                        <!-- 上传配置 -->
                                        <div class="upload-config" style="margin-top: 20px;">
                                            <el-divider>上传配置</el-divider>
                                            <el-form :inline="true" size="small">
                                                <el-form-item label="哈希算法：">
                                                    <el-select v-model="fileEvidenceHashAlgorithm" style="width: 120px;">
                                                        <el-option label="SHA256" value="SHA256"></el-option>
                                                        <el-option label="MD5" value="MD5"></el-option>
                                                        <el-option label="SHA1" value="SHA1"></el-option>
                                                    </el-select>
                                                </el-form-item>
                                                <el-form-item label="描述信息：">
                                                    <el-input v-model="fileEvidenceDescription" placeholder="可选：输入文件描述" style="width: 200px;"></el-input>
                                                </el-form-item>
                                                <el-form-item>
                                                    <el-button type="primary" :disabled="!canUploadFileEvidence" @click="submitFileEvidenceUpload">
                                                        <i class="el-icon-upload2"></i> 开始上传
                                                    </el-button>
                                                </el-form-item>
                                            </el-form>
                                        </div>
                                    </el-card>
                                </el-col>

                                <!-- 快速操作和统计 -->
                                <el-col :span="8">
                                    <el-card shadow="hover" style="margin-bottom: 20px;">
                                        <div slot="header">
                                            <i class="el-icon-s-data"></i> 统计信息
                                        </div>
                                        <div class="statistics-grid">
                                            <div class="stat-item">
                                                <div class="stat-number">{{ fileEvidenceStats.totalGroups || 0 }}</div>
                                                <div class="stat-label">分组总数</div>
                                            </div>
                                            <div class="stat-item">
                                                <div class="stat-number">{{ fileEvidenceStats.totalProjects || 0 }}</div>
                                                <div class="stat-label">项目总数</div>
                                            </div>
                                            <div class="stat-item">
                                                <div class="stat-number">{{ fileEvidenceStats.totalFiles || 0 }}</div>
                                                <div class="stat-label">文件总数</div>
                                            </div>
                                            <div class="stat-item">
                                                <div class="stat-number">{{ fileEvidenceStats.todayFiles || 0 }}</div>
                                                <div class="stat-label">今日上传</div>
                                            </div>
                                        </div>
                                    </el-card>

                                    <el-card shadow="hover">
                                        <div slot="header">
                                            <i class="el-icon-tickets"></i> 快速操作
                                        </div>
                                        <el-button-group style="width: 100%; display: flex; flex-direction: column; gap: 10px;">
                                            <el-button type="primary" plain @click="fileEvidenceActiveView='groups'">
                                                <i class="el-icon-folder"></i> 管理分组
                                            </el-button>
                                            <el-button type="success" plain @click="fileEvidenceActiveView='projects'">
                                                <i class="el-icon-folder-opened"></i> 管理项目
                                            </el-button>
                                            <el-button type="info" plain @click="fileEvidenceActiveView='files'">
                                                <i class="el-icon-document"></i> 查看文件
                                            </el-button>
                                        </el-button-group>
                                    </el-card>
                                </el-col>
                            </el-row>
                        </div>

                        <!-- 分组管理视图 -->
                        <div v-if="fileEvidenceActiveView === 'groups'">
                            <el-card shadow="hover">
                                <div slot="header">
                                    <span><i class="el-icon-folder"></i> 分组管理</span>
                                    <div style="float: right;">
                                        <el-input v-model="groupSearchKeyword" placeholder="搜索分组" size="small" style="width: 200px; margin-right: 10px;">
                                            <el-button slot="append" icon="el-icon-search"></el-button>
                                        </el-input>
                                    </div>
                                </div>
                                <el-table :data="groupList" v-loading="groupListLoading">
                                    <el-table-column prop="groupName" label="分组名称" sortable></el-table-column>
                                    <el-table-column prop="groupCode" label="分组代码" width="150"></el-table-column>
                                    <el-table-column prop="description" label="描述" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="status" label="状态" width="100">
                                        <template slot-scope="scope">
                                            <el-tag :type="scope.row.status === 1 ? 'success' : 'danger'" size="small">
                                                {{ scope.row.status === 1 ? '启用' : '禁用' }}
                                            </el-tag>
                                        </template>
                                    </el-table-column>
                                    <el-table-column prop="createdAt" label="创建时间" width="180">
                                        <template slot-scope="scope">
                                            {{ formatDateTime(scope.row.createdAt) }}
                                        </template>
                                    </el-table-column>
                                    <el-table-column label="操作" width="200">
                                        <template slot-scope="scope">
                                            <el-button size="mini" @click="editGroup(scope.row)">编辑</el-button>
                                            <el-button size="mini" :type="scope.row.status === 1 ? 'warning' : 'success'" 
                                                @click="toggleGroupStatus(scope.row)">
                                                {{ scope.row.status === 1 ? '禁用' : '启用' }}
                                            </el-button>
                                        </template>
                                    </el-table-column>
                                </el-table>
                                <el-pagination
                                    @size-change="handleGroupSizeChange"
                                    @current-change="handleGroupCurrentChange"
                                    :current-page="groupPagination.current"
                                    :page-sizes="[10, 20, 50]"
                                    :page-size="groupPagination.size"
                                    layout="total, sizes, prev, pager, next, jumper"
                                    :total="groupPagination.total"
                                    style="text-align: center; margin-top: 20px;">
                                </el-pagination>
                            </el-card>
                        </div>

                        <!-- 项目管理视图 -->
                        <div v-if="fileEvidenceActiveView === 'projects'">
                            <el-card shadow="hover">
                                <div slot="header">
                                    <span><i class="el-icon-folder-opened"></i> 项目管理</span>
                                    <div style="float: right;">
                                        <el-select v-model="projectFilterGroupId" placeholder="筛选分组" size="small" clearable style="width: 150px; margin-right: 10px;">
                                            <el-option v-for="group in userGroups" :key="group.id" :label="group.groupName" :value="group.id"></el-option>
                                        </el-select>
                                        <el-input v-model="projectSearchKeyword" placeholder="搜索项目" size="small" style="width: 200px; margin-right: 10px;">
                                            <el-button slot="append" icon="el-icon-search"></el-button>
                                        </el-input>
                                    </div>
                                </div>
                                <el-table :data="projectList" v-loading="projectListLoading">
                                    <el-table-column prop="projectName" label="项目名称" sortable></el-table-column>
                                    <el-table-column prop="projectCode" label="项目代码" width="120"></el-table-column>
                                    <el-table-column prop="groupName" label="所属分组" width="120"></el-table-column>
                                    <el-table-column prop="description" label="描述" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="status" label="状态" width="100">
                                        <template slot-scope="scope">
                                            <el-tag :type="scope.row.status === 1 ? 'success' : 'danger'" size="small">
                                                {{ scope.row.status === 1 ? '启用' : '禁用' }}
                                            </el-tag>
                                        </template>
                                    </el-table-column>
                                    <el-table-column prop="createdAt" label="创建时间" width="180">
                                        <template slot-scope="scope">
                                            {{ formatDateTime(scope.row.createdAt) }}
                                        </template>
                                    </el-table-column>
                                    <el-table-column label="操作" width="200">
                                        <template slot-scope="scope">
                                            <el-button size="mini" @click="editProject(scope.row)">编辑</el-button>
                                            <el-button size="mini" :type="scope.row.status === 1 ? 'warning' : 'success'" 
                                                @click="toggleProjectStatus(scope.row)">
                                                {{ scope.row.status === 1 ? '禁用' : '启用' }}
                                            </el-button>
                                        </template>
                                    </el-table-column>
                                </el-table>
                                <el-pagination
                                    @size-change="handleProjectSizeChange"
                                    @current-change="handleProjectCurrentChange"
                                    :current-page="projectPagination.current"
                                    :page-sizes="[10, 20, 50]"
                                    :page-size="projectPagination.size"
                                    layout="total, sizes, prev, pager, next, jumper"
                                    :total="projectPagination.total"
                                    style="text-align: center; margin-top: 20px;">
                                </el-pagination>
                            </el-card>
                        </div>

                        <!-- 文件列表视图 -->
                        <div v-if="fileEvidenceActiveView === 'files'">
                            <el-card shadow="hover">
                                <div slot="header">
                                    <span><i class="el-icon-document"></i> 文件列表</span>
                                    <div style="float: right;">
                                        <el-select v-model="fileFilterGroupId" placeholder="筛选分组" size="small" clearable style="width: 150px; margin-right: 10px;">
                                            <el-option v-for="group in userGroups" :key="group.id" :label="group.groupName" :value="group.id"></el-option>
                                        </el-select>
                                        <el-select v-model="fileFilterProjectId" placeholder="筛选项目" size="small" clearable style="width: 150px; margin-right: 10px;">
                                            <el-option v-for="project in userProjects" :key="project.id" :label="project.projectName" :value="project.id"></el-option>
                                        </el-select>
                                        <el-date-picker v-model="fileFilterTimeRange" type="datetimerange" range-separator="至" start-placeholder="开始时间" end-placeholder="结束时间" size="small" style="width: 300px; margin-right: 10px;" format="yyyy-MM-dd HH:mm:ss" value-format="yyyy-MM-dd HH:mm:ss"></el-date-picker>
                                        <el-input v-model="fileSearchKeyword" placeholder="搜索文件名" size="small" style="width: 200px; margin-right: 10px;">
                                            <el-button slot="append" icon="el-icon-search" @click="loadFileEvidenceList"></el-button>
                                        </el-input>
                                        <el-button type="primary" size="small" icon="el-icon-refresh" @click="resetFileSearch">重置</el-button>
                                    </div>
                                </div>
                                <el-table :data="fileEvidenceList" v-loading="fileEvidenceListLoading">
                                    <el-table-column prop="fileName" label="文件名" sortable show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="groupName" label="所属分组" width="120" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="projectName" label="所属项目" width="120" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="fileSize" label="文件大小" width="120">
                                        <template slot-scope="scope">
                                            {{ formatFileSize(scope.row.fileSize) }}
                                        </template>
                                    </el-table-column>
                                    <el-table-column prop="chainStatus" label="上链状态" width="120">
                                        <template slot-scope="scope">
                                            <el-tag :type="getChainStatusType(scope.row.chainStatus)" size="small">
                                                {{ getChainStatusText(scope.row.chainStatus) }}
                                            </el-tag>
                                        </template>
                                    </el-table-column>
                                    <el-table-column prop="commitMessage" label="提交信息" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="createdAt" label="上传时间" width="180">
                                        <template slot-scope="scope">
                                            {{ formatDateTime(scope.row.createdAt) }}
                                        </template>
                                    </el-table-column>
                                    <el-table-column label="操作" width="150">
                                        <template slot-scope="scope">
                                            <el-button size="mini" @click="viewFileEvidence(scope.row)">详情</el-button>
                                            <el-button size="mini" type="success" @click="verifyFileEvidence(scope.row.fileHash)">验证</el-button>
                                        </template>
                                    </el-table-column>
                                </el-table>
                                <el-pagination
                                    @size-change="handleFileEvidenceSizeChange"
                                    @current-change="handleFileEvidenceCurrentChange"
                                    :current-page="fileEvidencePagination.current"
                                    :page-sizes="[10, 20, 50]"
                                    :page-size="fileEvidencePagination.size"
                                    layout="total, sizes, prev, pager, next, jumper"
                                    :total="fileEvidencePagination.total"
                                    style="text-align: center; margin-top: 20px;">
                                </el-pagination>
                            </el-card>
                        </div>

                        <!-- 操作日志视图 -->
                        <div v-if="fileEvidenceActiveView === 'logs'">
                            <el-card shadow="hover">
                                <div slot="header">
                                    <span><i class="el-icon-document-copy"></i> 操作日志</span>
                                    <div style="float: right;">
                                        <el-select v-model="logFilterOperationType" placeholder="操作类型" size="small" clearable style="width: 120px; margin-right: 10px;">
                                            <el-option label="创建分组" value="CREATE_GROUP"></el-option>
                                            <el-option label="创建项目" value="CREATE_PROJECT"></el-option>
                                            <el-option label="上传文件" value="UPLOAD_FILE"></el-option>
                                            <el-option label="批量上传" value="BATCH_UPLOAD_FILE"></el-option>
                                        </el-select>
                                    </div>
                                </div>
                                <el-table :data="operationLogList" v-loading="operationLogListLoading">
                                    <el-table-column prop="operationType" label="操作类型" width="120">
                                        <template slot-scope="scope">
                                            <el-tag size="small" :type="getOperationTypeTag(scope.row.operationType)">
                                                {{ getOperationTypeText(scope.row.operationType) }}
                                            </el-tag>
                                        </template>
                                    </el-table-column>
                                    <el-table-column prop="targetName" label="目标名称" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="operationDetails" label="操作详情" show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="operationResult" label="结果" width="80">
                                        <template slot-scope="scope">
                                            <el-tag :type="scope.row.operationResult === 1 ? 'success' : 'danger'" size="small">
                                                {{ scope.row.operationResult === 1 ? '成功' : '失败' }}
                                            </el-tag>
                                        </template>
                                    </el-table-column>
                                    <el-table-column prop="createdAt" label="操作时间" width="180">
                                        <template slot-scope="scope">
                                            {{ formatDateTime(scope.row.createdAt) }}
                                        </template>
                                    </el-table-column>
                                </el-table>
                                <el-pagination
                                    @size-change="handleLogSizeChange"
                                    @current-change="handleLogCurrentChange"
                                    :current-page="logPagination.current"
                                    :page-sizes="[10, 20, 50]"
                                    :page-size="logPagination.size"
                                    layout="total, sizes, prev, pager, next, jumper"
                                    :total="logPagination.total"
                                    style="text-align: center; margin-top: 20px;">
                                </el-pagination>
                            </el-card>
                        </div>
                        
                        <!-- 传统的文件上传区域 -->
                        <div v-if="false" style="display: none;">
                            <el-row :gutter="20">
                                <el-col :span="24">
                                    <el-card class="upload-card" shadow="hover">
                                        <div slot="header">
                                            <span><i class="el-icon-upload2"></i> 文件上传存证</span>
                                            <div class="card-header-right">
                                                <el-tag size="small">支持格式：文档、图片、压缩包、代码脚本等多种类型</el-tag>
                                            </div>
                                        </div>

                                    <!-- 上传区域 -->
                                    <el-upload
                                            class="upload-dragger"
                                            :action="uploadAction"
                                            :headers="uploadHeaders"
                                            :data="uploadData"
                                            :on-success="handleUploadSuccess"
                                            :on-error="handleUploadError"
                                            :on-progress="handleUploadProgress"
                                            :on-change="handleFileChange"
                                            :on-remove="handleFileRemove"
                                            :before-upload="beforeUpload"
                                            :file-list="fileList"
                                            drag
                                            :limit="1"
                                            :auto-upload="false"
                                            ref="upload">
                                        <i class="el-icon-upload"></i>
                                        <div class="el-upload__text">将文件拖到此处，或<em>点击上传</em></div>
                                        <div class="el-upload__tip" slot="tip">
                                            <div>只能上传单个文件，且不超过100MB</div>
                                            <div style="margin-top: 5px; font-size: 12px; color: #909399;">
                                                <strong>支持格式：</strong><br/>
                                                📄 文档类：PDF、DOC、DOCX、XLS、XLSX、PPT、PPTX、RTF、TXT、CSV<br/>
                                                🖼️ 图片类：JPG、PNG、GIF、BMP、TIFF、WEBP、SVG<br/>
                                                📦 压缩包：ZIP、RAR、7Z、TAR、GZ<br/>
                                                💻 代码类：PY、JAVA、C、CPP、JS、HTML、CSS、XML、SQL、SOL等
                                            </div>
                                        </div>
                                    </el-upload>

                                    <!-- 文字内容存证区域 -->
                                    <div class="text-content-section" style="margin-top: 20px;">
                                        <el-divider>
                                            <el-tag type="info">或者直接输入信息内容进行存证</el-tag>
                                        </el-divider>
                                        <h4 style="margin-bottom: 10px;">
                                            <i class="el-icon-edit-outline"></i> 文字内容存证
                                        </h4>
                                        <p style="color: #909399; margin-bottom: 15px; font-size: 13px;">
                                            您可以直接输入文字内容进行存证，支持代码、文档、协议等任意文本信息
                                        </p>
                                        <el-input
                                            v-model="textContent"
                                            type="textarea"
                                            :autosize="{ minRows: 6, maxRows: 15 }"
                                            placeholder="请输入要存证的文字内容（支持文本、代码、JSON等）&#10;&#10;示例：&#10;- 重要协议条款&#10;- 代码片段&#10;- 创意文案&#10;- 技术文档&#10;等等..."
                                            maxlength="50000"
                                            show-word-limit
                                            class="text-editor">
                                        </el-input>
                                        <div v-if="textContent && textContent.trim()" class="text-info" style="margin-top: 10px;">
                                            <el-tag size="small" type="success">
                                                文字长度: {{ textContent.trim().length }} 字符
                                            </el-tag>
                                            <el-tag size="small" type="info" style="margin-left: 10px;">
                                                预计哈希: {{ textContent.trim().length > 0 ? uploadData.hashAlgorithm : '无' }}
                                            </el-tag>
                                        </div>
                                    </div>

                                    <!-- 文件信息显示 -->
                                    <div v-if="fileList.length > 0" class="file-info-section" style="margin-top: 20px;">
                                        <h4 style="margin-bottom: 10px;">
                                            <i class="el-icon-document"></i> 文件信息
                                        </h4>
                                        <el-descriptions :column="2" border size="small">
                                            <el-descriptions-item label="文件名">{{ currentFile.name }}</el-descriptions-item>
                                            <el-descriptions-item label="文件大小">{{ formatFileSize(currentFile.size) }}</el-descriptions-item>
                                            <el-descriptions-item label="文件类型">{{ currentFile.raw && currentFile.raw.type || '未知' }}</el-descriptions-item>
                                            <el-descriptions-item label="最后修改">{{ formatDate(currentFile.raw && currentFile.raw.lastModified) }}</el-descriptions-item>
                                        </el-descriptions>
                                    </div>

                                    <!-- 上传进度显示 -->
                                    <div v-if="uploadLoading" class="upload-progress-section" style="margin-top: 20px;">
                                        <h4 style="margin-bottom: 10px;">
                                            <i class="el-icon-loading"></i> 上传进度
                                        </h4>
                                        <el-progress 
                                            :percentage="uploadProgress" 
                                            :status="uploadStatus || undefined" 
                                            :stroke-width="20" 
                                        />
                                        <p style="margin-top: 10px; color: #606266; font-size: 14px;">{{ progressText }}</p>
                                    </div>

                                    <!-- 上传配置 -->
                                    <el-form :inline="true" class="upload-form" label-width="100px">
                                        <el-form-item label="描述信息：">
                                            <el-input
                                                    v-model="uploadData.description"
                                                    placeholder="请输入文件描述信息（可选）"
                                                    style="width: 300px;"
                                                    maxlength="200"
                                                    show-word-limit>
                                            </el-input>
                                        </el-form-item>
                                        <el-form-item label="哈希算法：">
                                            <el-select v-model="uploadData.hashAlgorithm" style="width: 120px;">
                                                <el-option label="SHA256" value="SHA256"></el-option>
                                                <el-option label="SM3" value="SM3"></el-option>
                                            </el-select>
                                        </el-form-item>
                                        <el-form-item>
                                            <el-button
                                                    type="primary"
                                                    @click="submitUpload"
                                                    :loading="uploadLoading"
                                                    :disabled="!canUpload">
                                                <i class="el-icon-upload2"></i>
                                                开始上传存证
                                            </el-button>
                                            <el-button @click="clearFiles">清空文件</el-button>
                                            <el-button @click="clearTextContent" v-if="textContent">清空文字</el-button>
                                        </el-form-item>
                                    </el-form>
                                </el-card>
                            </el-col>
                        </el-row>

                        <!-- 最近上传 -->
                        <el-row style="margin-top: 20px;">
                            <el-col :span="24">
                                <el-card shadow="hover">
                                    <div slot="header">
                                        <span><i class="el-icon-time"></i> 最近上传</span>
                                        <el-button style="float: right;" type="text" @click="refreshRecentUploads">
                                            <i class="el-icon-refresh"></i> 刷新
                                        </el-button>
                                    </div>
                                    <el-table :data="recentUploads" v-loading="recentLoading" height="300">
                                        <el-table-column prop="fileName" label="文件名" min-width="150"></el-table-column>
                                        <el-table-column prop="fileSize" label="大小" width="100">
                                            <template slot-scope="scope">
                                                {{ formatFileSize(scope.row.fileSize) }}
                                            </template>
                                        </el-table-column>
                                        <el-table-column prop="chainStatus" label="状态" width="100">
                                            <template slot-scope="scope">
                                                <el-tag :type="getStatusType(scope.row.chainStatus)" size="mini">
                                                    {{ getStatusText(scope.row.chainStatus) }}
                                                </el-tag>
                                            </template>
                                        </el-table-column>
                                        <el-table-column prop="createdAt" label="上传时间" width="180">
                                            <template slot-scope="scope">
                                                {{ formatDate(scope.row.createdAt) }}
                                            </template>
                                        </el-table-column>
                                        <el-table-column label="操作" width="120">
                                            <template slot-scope="scope">
                                                <el-button size="mini" @click="viewDetail(scope.row)">详情</el-button>
                                            </template>
                                        </el-table-column>
                                    </el-table>
                                </el-card>
                            </el-col>
                        </el-row>
                    </div>
                </el-tab-pane>

                <!-- 代码存证Tab -->
                <el-tab-pane label="代码存证" name="code">
                    <div class="tab-content" style="min-height: 600px; background-color: #f9f9f9; padding: 20px;">
                        <!-- 调试信息 -->
                        <el-alert title="代码存证模块已加载" type="success" style="margin-bottom: 20px;" show-icon>
                            <div>当前Tab: {{ activeTab }}</div>
                            <div>用户信息: {{ userInfo ? '已登录' : '未登录' }}</div>
                            <div>仓库数量: {{ repositories.length }}</div>
                            <div>存证记录数量: {{ codeEvidenceList.length }}</div>
                        </el-alert>
                        
                        <!-- 额外调试信息 -->
                        <div style="background: yellow; padding: 10px; margin-bottom: 20px; border: 2px solid red;">
                            <p><strong>调试：下面应该显示代码存证内容</strong></p>
                            <p>repositoryForm: {{ JSON.stringify(repositoryForm) }}</p>
                            <p>selectedRepository: {{ selectedRepository }}</p>
                            <p>codeLoading: {{ JSON.stringify(codeLoading) }}</p>
                        </div>
                        <!-- 仓库管理区域 -->
                        <el-row :gutter="20" style="margin-bottom: 20px; background: lightblue; padding: 10px;">
                            <el-col :span="12" style="background: lightgreen; padding: 5px;">
                                <el-card shadow="hover" class="repository-card" style="background: white; min-height: 300px;">
                                    <div slot="header">
                                        <span><i class="el-icon-folder-add"></i> 创建新仓库</span>
                                    </div>
                                    <el-form :model="repositoryForm" :rules="repositoryRules" ref="repositoryForm" label-width="100px" size="small">
                                        <el-form-item label="分组名称" prop="groupName">
                                            <el-input v-model="repositoryForm.groupName" placeholder="请输入分组名称(字母数字下划线)"></el-input>
                                        </el-form-item>
                                        <el-form-item label="项目名称" prop="projectName">
                                            <el-input v-model="repositoryForm.projectName" placeholder="请输入项目名称(字母数字下划线)"></el-input>
                                        </el-form-item>
                                        <el-form-item label="项目描述">
                                            <el-input type="textarea" v-model="repositoryForm.description" placeholder="请输入项目描述(可选)"></el-input>
                                        </el-form-item>
                                        <el-form-item>
                                            <el-button type="primary" @click="createRepository" :loading="codeLoading.createRepo">
                                                创建仓库
                                            </el-button>
                                        </el-form-item>
                                    </el-form>
                                </el-card>
                            </el-col>
                            <el-col :span="12" style="background: lightyellow; padding: 5px;">
                                <el-card shadow="hover" class="branch-card" style="background: white; min-height: 300px;">
                                    <div slot="header">
                                        <span><i class="el-icon-s-operation"></i> 仓库管理</span>
                                        <el-button style="float: right; padding: 3px 0" type="text" @click="loadRepositories">刷新</el-button>
                                    </div>
                                    <el-select v-model="selectedRepository" placeholder="选择仓库" @change="onRepositoryChange" style="width: 100%; margin-bottom: 15px;">
                                        <el-option
                                            v-for="repo in repositories"
                                            :key="repo.id"
                                            :label="repo.groupName + '/' + repo.projectName"
                                            :value="repo.id">
                                        </el-option>
                                    </el-select>
                                    <div v-if="selectedRepository">
                                        <el-tabs v-model="branchTabActive" size="small">
                                            <el-tab-pane label="创建分支" name="create">
                                                <el-input v-model="branchForm.branchName" placeholder="新分支名称" size="small" style="margin-bottom: 10px;"></el-input>
                                                <el-input v-model="branchForm.baseBranch" placeholder="基础分支(默认main)" size="small" style="margin-bottom: 10px;"></el-input>
                                                <el-button type="success" size="small" @click="createBranch" :loading="codeLoading.createBranch">
                                                    创建分支
                                                </el-button>
                                            </el-tab-pane>
                                            <el-tab-pane label="合并分支" name="merge">
                                                <el-select v-model="mergeForm.sourceBranch" placeholder="源分支" size="small" style="width: 100%; margin-bottom: 10px;">
                                                    <el-option
                                                        v-for="branch in branches"
                                                        :key="branch.id"
                                                        :label="branch.branchName"
                                                        :value="branch.branchName">
                                                    </el-option>
                                                </el-select>
                                                <el-select v-model="mergeForm.targetBranch" placeholder="目标分支" size="small" style="width: 100%; margin-bottom: 10px;">
                                                    <el-option
                                                        v-for="branch in branches"
                                                        :key="branch.id"
                                                        :label="branch.branchName"
                                                        :value="branch.branchName">
                                                    </el-option>
                                                </el-select>
                                                <el-button type="primary" size="small" @click="mergeBranch" :loading="codeLoading.merge" :disabled="!mergeForm.sourceBranch || !mergeForm.targetBranch">
                                                    合并分支
                                                </el-button>
                                            </el-tab-pane>
                                        </el-tabs>
                                    </div>
                                </el-card>
                            </el-col>
                        </el-row>

                        <!-- 代码上传区域 -->
                        <el-card shadow="hover" class="code-upload-card" style="background: lightcoral; margin-bottom: 20px; min-height: 400px;">
                            <div slot="header">
                                <span><i class="el-icon-upload2"></i> 代码文件上传</span>
                                <div class="card-header-right">
                                    <el-tag size="small">支持格式：py, java, js, ts, html, css, sql, json, xml, c, cpp, go, rs等</el-tag>
                                </div>
                            </div>
                            <el-row :gutter="20">
                                <el-col :span="16">
                                    <div class="code-upload-area">
                                        <el-upload
                                            ref="codeUpload"
                                            action="#"
                                            :auto-upload="false"
                                            :on-change="handleCodeFileSelect"
                                            :file-list="codeFileList"
                                            :show-file-list="true"
                                            accept=".py,.java,.js,.ts,.html,.css,.sql,.json,.xml,.c,.cpp,.h,.hpp,.go,.rs,.php,.rb,.swift,.kt,.scala,.sol,.vue,.jsx,.tsx"
                                            drag
                                            multiple>
                                            <i class="el-icon-upload" style="font-size: 67px; color: #c0c4cc; margin-bottom: 16px;"></i>
                                            <div style="color: #606266; font-size: 14px; margin-bottom: 16px;">
                                                将代码文件拖到此处，或<em style="color: #409EFF;">点击上传</em>
                                            </div>
                                            <div style="color: #909399; font-size: 12px; margin-top: 10px;">
                                                支持的文件类型：.py .java .js .ts .html .css .sql .json .xml .c .cpp .h .hpp .go .rs .php .rb .swift .kt .scala .sol .vue .jsx .tsx
                                                <br>单文件大小限制：10MB
                                            </div>
                                        </el-upload>
                                    </div>
                                </el-col>
                                <el-col :span="8">
                                    <el-form :model="uploadForm" label-width="80px" size="small">
                                        <el-form-item label="目标仓库">
                                            <el-select v-model="uploadForm.repositoryId" placeholder="选择仓库" style="width: 100%;">
                                                <el-option
                                                    v-for="repo in repositories"
                                                    :key="repo.id"
                                                    :label="repo.groupName + '/' + repo.projectName"
                                                    :value="repo.id">
                                                </el-option>
                                            </el-select>
                                        </el-form-item>
                                        <el-form-item label="目标分支">
                                            <el-select v-model="uploadForm.branchName" placeholder="选择分支" style="width: 100%;">
                                                <el-option
                                                    v-for="branch in branches"
                                                    :key="branch.id"
                                                    :label="branch.branchName"
                                                    :value="branch.branchName">
                                                </el-option>
                                            </el-select>
                                        </el-form-item>
                                        <el-form-item label="上传模式">
                                            <el-radio-group v-model="uploadForm.uploadMode" size="small">
                                                <el-radio label="single">单文件提交</el-radio>
                                                <el-radio label="batch">批量提交</el-radio>
                                            </el-radio-group>
                                            <div style="margin-top: 5px; font-size: 12px; color: #909399;">
                                                单文件：每个文件单独创建提交；批量：所有文件合并为一次提交
                                            </div>
                                        </el-form-item>
                                        <el-form-item label="提交信息">
                                            <el-input type="textarea" v-model="uploadForm.commitMessage" placeholder="请输入提交信息" :rows="3"></el-input>
                                        </el-form-item>
                                        <el-form-item>
                                            <el-button type="primary" @click="uploadCode" :loading="codeLoading.upload" :disabled="codeFileList.length === 0">
                                                提交代码
                                            </el-button>
                                            <el-button @click="clearCodeFiles">清空</el-button>
                                        </el-form-item>
                                    </el-form>
                                </el-col>
                            </el-row>
                        </el-card>

                        <!-- 代码存证记录 -->
                        <el-card shadow="hover" style="margin-top: 20px;">
                            <div slot="header">
                                <span><i class="el-icon-document-checked"></i> 代码存证记录</span>
                                <el-button style="float: right; padding: 3px 0" type="text" @click="loadCodeEvidenceList">刷新</el-button>
                            </div>
                            <el-table :data="codeEvidenceList" style="width: 100%" v-loading="codeLoading.table">
                                <el-table-column prop="fileName" label="文件名" width="200"></el-table-column>
                                <el-table-column prop="gitGroupName" label="分组" width="120"></el-table-column>
                                <el-table-column prop="gitProjectName" label="项目" width="120"></el-table-column>
                                <el-table-column prop="gitBranchName" label="分支" width="100">
                                    <template slot-scope="scope">
                                        <el-tag size="small" type="info">{{ scope.row.gitBranchName }}</el-tag>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="gitCommitHash" label="提交哈希" width="120">
                                    <template slot-scope="scope">
                                        <el-tooltip :content="scope.row.gitCommitHash" placement="top">
                                            <span style="font-family: monospace;">{{ scope.row.gitCommitHash ? scope.row.gitCommitHash.substring(0, 8) : '-' }}</span>
                                        </el-tooltip>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="chainStatus" label="链上状态" width="100">
                                    <template slot-scope="scope">
                                        <el-tag :type="getChainStatusType(scope.row.chainStatus)" size="small">
                                            {{ getChainStatusText(scope.row.chainStatus) }}
                                        </el-tag>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="createdAt" label="存证时间" width="160"></el-table-column>
                                <el-table-column label="操作" width="150">
                                    <template slot-scope="scope">
                                        <el-button size="mini" type="text" @click="viewCodeDetails(scope.row)">详情</el-button>
                                        <el-button size="mini" type="text" @click="downloadCode(scope.row)">下载</el-button>
                                    </template>
                                </el-table-column>
                            </el-table>
                        </el-card>

                        <!-- 统计信息 -->
                        <el-row :gutter="20" style="margin-top: 20px;">
                            <el-col :span="6">
                                <el-card shadow="hover" class="stat-card">
                                    <div class="stat-content">
                                        <div class="stat-value">{{ stats.totalRepositories }}</div>
                                        <div class="stat-label">总仓库数</div>
                                    </div>
                                </el-card>
                            </el-col>
                            <el-col :span="6">
                                <el-card shadow="hover" class="stat-card">
                                    <div class="stat-content">
                                        <div class="stat-value">{{ stats.totalBranches }}</div>
                                        <div class="stat-label">总分支数</div>
                                    </div>
                                </el-card>
                            </el-col>
                            <el-col :span="6">
                                <el-card shadow="hover" class="stat-card">
                                    <div class="stat-content">
                                        <div class="stat-value">{{ stats.totalCommits }}</div>
                                        <div class="stat-label">总提交数</div>
                                    </div>
                                </el-card>
                            </el-col>
                            <el-col :span="6">
                                <el-card shadow="hover" class="stat-card">
                                    <div class="stat-content">
                                        <div class="stat-value">{{ stats.todayCommits }}</div>
                                        <div class="stat-label">今日提交</div>
                                    </div>
                                </el-card>
                            </el-col>
                        </el-row>
                    </div>
                </el-tab-pane>

                <!-- 查询验证Tab -->
                <el-tab-pane label="查询验证" name="query">
                    <div class="tab-content" style="min-height: 600px; background-color: #f0f8ff; padding: 20px;">
                        <!-- 调试信息 -->
                        <el-alert title="查询验证模块已加载" type="info" style="margin-bottom: 20px;" show-icon>
                            <div>当前Tab: {{ activeTab }}</div>
                            <div>用户信息: {{ userInfo ? '已登录' : '未登录' }}</div>
                            <div>存证记录数量: {{ evidenceList.length }}</div>
                        </el-alert>
                        <!-- 查询条件 -->
                        <el-card shadow="hover" class="query-card">
                            <div slot="header">
                                <span><i class="el-icon-search"></i> 存证查询</span>
                            </div>
                            <el-form :inline="true" :model="queryForm" class="query-form">
                                <el-form-item label="文件名：">
                                    <el-input
                                            v-model="queryForm.fileName"
                                            placeholder="输入文件名关键词"
                                            clearable
                                            style="width: 200px;">
                                    </el-input>
                                </el-form-item>
                                <el-form-item label="文件哈希：">
                                    <el-input
                                            v-model="queryForm.fileHash"
                                            placeholder="输入完整文件哈希"
                                            clearable
                                            style="width: 300px;">
                                    </el-input>
                                </el-form-item>
                                <el-form-item label="交易哈希：">
                                    <el-input
                                            v-model="queryForm.transactionHash"
                                            placeholder="输入交易哈希"
                                            clearable
                                            style="width: 300px;">
                                    </el-input>
                                </el-form-item>
                                <el-form-item label="区块号：">
                                    <el-input
                                            v-model="queryForm.blockNumber"
                                            placeholder="输入区块号"
                                            clearable
                                            style="width: 150px;">
                                    </el-input>
                                </el-form-item>
                                <el-form-item label="状态：">
                                    <el-select v-model="queryForm.chainStatus" placeholder="选择状态" clearable style="width: 120px;">
                                        <el-option label="待上链" :value="0"></el-option>
                                        <el-option label="上链成功" :value="1"></el-option>
                                        <el-option label="上链失败" :value="2"></el-option>
                                    </el-select>
                                </el-form-item>
                                <el-form-item label="时间范围：">
                                    <el-date-picker
                                            v-model="dateRange"
                                            type="datetimerange"
                                            range-separator="至"
                                            start-placeholder="开始日期"
                                            end-placeholder="结束日期"
                                            style="width: 350px;">
                                    </el-date-picker>
                                </el-form-item>
                                <el-form-item>
                                    <el-button type="primary" @click="handleQuery">
                                        <i class="el-icon-search"></i> 查询
                                    </el-button>
                                    <el-button @click="resetQuery">
                                        <i class="el-icon-refresh"></i> 重置
                                    </el-button>
                                    <el-button type="success" @click="showQuickVerify">
                                        <i class="el-icon-check"></i> 快速验证
                                    </el-button>
                                </el-form-item>
                            </el-form>
                        </el-card>

                        <!-- 查询结果 -->
                        <el-card shadow="hover" style="margin-top: 20px;">
                            <div slot="header">
                                <span><i class="el-icon-document"></i> 存证记录</span>
                                <div class="card-header-right">
                                    <el-button size="small" @click="refreshData">
                                        <i class="el-icon-refresh"></i> 刷新
                                    </el-button>
                                    <el-button size="small" type="primary" @click="exportData">
                                        <i class="el-icon-download"></i> 导出
                                    </el-button>
                                </div>
                            </div>
                            <el-table
                                    :data="evidenceList"
                                    v-loading="tableLoading"
                                    stripe
                                    border
                                    height="400">
                                <el-table-column type="index" label="序号" width="60"></el-table-column>
                                <el-table-column prop="fileName" label="文件名" min-width="150" show-overflow-tooltip>
                                    <template slot-scope="scope">
                                        <i class="el-icon-document"></i>
                                        {{ scope.row.fileName }}
                                    </template>
                                </el-table-column>
                                <el-table-column prop="fileHash" label="文件哈希" min-width="200" show-overflow-tooltip>
                                    <template slot-scope="scope">
                                        <el-link type="primary" @click="copyToClipboard(scope.row.fileHash)">
                                            {{ scope.row.fileHash }}
                                        </el-link>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="fileSize" label="大小" width="100">
                                    <template slot-scope="scope">
                                        {{ formatFileSize(scope.row.fileSize) }}
                                    </template>
                                </el-table-column>
                                <el-table-column prop="chainStatus" label="状态" width="100">
                                    <template slot-scope="scope">
                                        <el-tag :type="getStatusType(scope.row.chainStatus)" size="mini">
                                            {{ getStatusText(scope.row.chainStatus) }}
                                        </el-tag>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="transactionHash" label="交易哈希" min-width="200" show-overflow-tooltip>
                                    <template slot-scope="scope">
                                        <el-link v-if="scope.row.transactionHash" type="success" @click="copyToClipboard(scope.row.transactionHash)">
                                            {{ scope.row.transactionHash }}
                                        </el-link>
                                        <span v-else class="text-muted">-</span>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="blockNumber" label="区块号" width="100">
                                    <template slot-scope="scope">
                                        <el-link v-if="scope.row.blockNumber" type="warning">
                                            {{ scope.row.blockNumber }}
                                        </el-link>
                                        <span v-else class="text-muted">-</span>
                                    </template>
                                </el-table-column>
                                <el-table-column prop="createdAt" label="创建时间" width="180">
                                    <template slot-scope="scope">
                                        {{ formatDate(scope.row.createdAt) }}
                                    </template>
                                </el-table-column>
                                <el-table-column label="操作" width="140" fixed="right">
                                    <template slot-scope="scope">
                                        <div style="display: flex; gap: 8px;">
                                            <el-button size="mini" type="warning" @click="viewDetail(scope.row)">详情</el-button>
                                            <el-button size="mini" type="success" @click="verifyEvidence(scope.row.fileHash)">验证</el-button>
                                        </div>
                                    </template>
                                </el-table-column>
                            </el-table>

                            <!-- 分页 -->
                            <el-pagination
                                    @size-change="handleSizeChange"
                                    @current-change="handleCurrentChange"
                                    :current-page="pagination.current"
                                    :page-sizes="[10, 20, 50, 100]"
                                    :page-size="pagination.size"
                                    layout="total, sizes, prev, pager, next, jumper"
                                    :total="pagination.total"
                                    class="pagination">
                            </el-pagination>
                        </el-card>
                    </div>
                </el-tab-pane>

                <!-- 区块链信息Tab -->
                <el-tab-pane label="区块链信息" name="blockchain">
                    <div class="tab-content" style="min-height: 600px; background-color: #fff8f0; padding: 20px;">
                        <!-- 调试信息 -->
                        <el-alert title="区块链信息模块已加载" type="warning" style="margin-bottom: 20px;" show-icon>
                            <div>当前Tab: {{ activeTab }}</div>
                            <div>用户信息: {{ userInfo ? '已登录' : '未登录' }}</div>
                            <div>连接状态: {{ blockchainInfo.connected ? '已连接' : '未连接' }}</div>
                        </el-alert>
                        <el-row :gutter="20">
                            <!-- 区块链状态 -->
                            <el-col :span="12">
                                <el-card shadow="hover" class="blockchain-card">
                                    <div slot="header">
                                        <span><i class="el-icon-connection"></i> 区块链状态</span>
                                    </div>
                                    <div class="blockchain-info">
                                        <el-row>
                                            <el-col :span="12">
                                                <div class="info-item">
                                                    <div class="info-label">当前块高</div>
                                                    <div class="info-value">{{ blockchainInfo.blockNumber || '-' }}</div>
                                                </div>
                                            </el-col>
                                            <el-col :span="12">
                                                <div class="info-item">
                                                    <div class="info-label">连接状态</div>
                                                    <div class="info-value">
                                                        <el-tag :type="blockchainInfo.connected ? 'success' : 'danger'" size="small">
                                                            {{ blockchainInfo.connected ? '已连接' : '未连接' }}
                                                        </el-tag>
                                                    </div>
                                                </div>
                                            </el-col>
                                        </el-row>
                                        <el-row style="margin-top: 20px;">
                                            <el-col :span="12">
                                                <div class="info-item">
                                                    <div class="info-label">合约地址</div>
                                                    <div class="info-value contract-address">
                                                        {{ contractAddress || '未配置' }}
                                                    </div>
                                                </div>
                                            </el-col>
                                            <el-col :span="12">
                                                <div class="info-item">
                                                    <div class="info-label">群组ID</div>
                                                    <div class="info-value">{{ blockchainInfo.groupId || 'group0' }}</div>
                                                </div>
                                            </el-col>
                                        </el-row>
                                        <el-button
                                                type="primary"
                                                size="small"
                                                @click="refreshBlockchainInfo"
                                                style="margin-top: 20px;">
                                            <i class="el-icon-refresh"></i> 刷新信息
                                        </el-button>
                                    </div>
                                </el-card>
                            </el-col>

                            <!-- 统计信息 -->
                            <el-col :span="12">
                                <el-card shadow="hover" class="stats-card">
                                    <div slot="header">
                                        <span><i class="el-icon-pie-chart"></i> 统计信息</span>
                                    </div>
                                    <div class="stats-info">
                                        <el-row>
                                            <el-col :span="8">
                                                <div class="stat-item">
                                                    <div class="stat-number">{{ statistics.totalFiles || 0 }}</div>
                                                    <div class="stat-label">总文件数</div>
                                                </div>
                                            </el-col>
                                            <el-col :span="8">
                                                <div class="stat-item">
                                                    <div class="stat-number">{{ statistics.todayFiles || 0 }}</div>
                                                    <div class="stat-label">今日上传</div>
                                                </div>
                                            </el-col>
                                            <el-col :span="8">
                                                <div class="stat-item">
                                                    <div class="stat-number">{{ statistics.successRate || '0%' }}</div>
                                                    <div class="stat-label">成功率</div>
                                                </div>
                                            </el-col>
                                        </el-row>
                                    </div>
                                </el-card>
                            </el-col>
                        </el-row>

                        <!-- 区块浏览器 -->
                        <el-row style="margin-top: 20px;">
                            <el-col :span="24">
                                <el-card shadow="hover">
                                    <div slot="header">
                                        <span><i class="el-icon-view"></i> 区块浏览器</span>
                                    </div>
                                    <el-form :inline="true">
                                        <el-form-item label="查询类型：">
                                            <el-select v-model="searchType" style="width: 120px;">
                                                <el-option label="区块号" value="block"></el-option>
                                                <el-option label="交易哈希" value="transaction"></el-option>
                                            </el-select>
                                        </el-form-item>
                                        <el-form-item label="查询值：">
                                            <el-input
                                                    v-model="searchValue"
                                                    :placeholder="searchType === 'block' ? '输入区块号' : '输入交易哈希'"
                                                    style="width: 400px;">
                                            </el-input>
                                        </el-form-item>
                                        <el-form-item>
                                            <el-button type="primary" @click="searchBlockchain">
                                                <i class="el-icon-search"></i> 查询
                                            </el-button>
                                        </el-form-item>
                                    </el-form>
                                    <div v-if="blockchainSearchResult" class="search-result">
                                        <el-alert
                                                title="查询结果"
                                                type="success"
                                                :closable="false"
                                                show-icon>
                                            <pre>{{ JSON.stringify(blockchainSearchResult, null, 2) }}</pre>
                                        </el-alert>
                                    </div>
                                </el-card>
                            </el-col>
                        </el-row>
                    </div>
                </el-tab-pane>
            </el-tabs>
        </el-main>

    <!-- 详情对话框 -->
    <el-dialog title="存证详情" :visible.sync="detailDialogVisible" width="70%" :before-close="handleCloseDetail">
        <el-descriptions :column="2" v-if="selectedEvidence" border>
            <el-descriptions-item label="文件名">
                <el-tag>{{ selectedEvidence.fileName }}</el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="文件大小">
                {{ formatFileSize(selectedEvidence.fileSize) }}
            </el-descriptions-item>
            <el-descriptions-item label="文件哈希" :span="2">
                <el-input :value="selectedEvidence.fileHash" readonly>
                    <el-button slot="append" @click="copyToClipboard(selectedEvidence.fileHash)">复制</el-button>
                </el-input>
            </el-descriptions-item>
            <el-descriptions-item label="哈希算法">
                {{ selectedEvidence.hashAlgorithm }}
            </el-descriptions-item>
            <el-descriptions-item label="上链状态">
                <el-tag :type="getStatusType(selectedEvidence.chainStatus)">
                    {{ getStatusText(selectedEvidence.chainStatus) }}
                </el-tag>
            </el-descriptions-item>
            <el-descriptions-item label="描述信息" :span="2">
                {{ selectedEvidence.description || '无' }}
            </el-descriptions-item>
            <el-descriptions-item label="交易哈希" :span="2" v-if="selectedEvidence.transactionHash">
                <el-input :value="selectedEvidence.transactionHash" readonly>
                    <el-button slot="append" @click="copyToClipboard(selectedEvidence.transactionHash)">复制</el-button>
                </el-input>
            </el-descriptions-item>
            <el-descriptions-item label="区块号" v-if="selectedEvidence.blockNumber">
                {{ selectedEvidence.blockNumber }}
            </el-descriptions-item>
            <el-descriptions-item label="合约地址" v-if="selectedEvidence.contractAddress">
                {{ selectedEvidence.contractAddress }}
            </el-descriptions-item>
            <el-descriptions-item label="创建时间">
                {{ formatDate(selectedEvidence.createdAt) }}
            </el-descriptions-item>
            <el-descriptions-item label="更新时间">
                {{ formatDate(selectedEvidence.updatedAt) }}
            </el-descriptions-item>
            <el-descriptions-item label="链上消息" :span="2" v-if="selectedEvidence.chainMessage">
                <el-alert :title="selectedEvidence.chainMessage" :type="selectedEvidence.chainStatus === 1 ? 'success' : 'error'" :closable="false"></el-alert>
            </el-descriptions-item>
        </el-descriptions>
        <div slot="footer" class="dialog-footer">
            <el-button @click="detailDialogVisible = false">关闭</el-button>
            <el-button type="success" @click="verifyEvidence(selectedEvidence.fileHash)">验证存证</el-button>
            <el-button type="primary" @click="viewOnChain(selectedEvidence)">查看上链信息</el-button>
        </div>
    </el-dialog>

    <!-- 快速验证对话框 -->
    <el-dialog title="快速验证" :visible.sync="quickVerifyVisible" width="50%">
        <el-form>
            <el-form-item label="文件哈希：">
                <el-input v-model="quickVerifyHash" placeholder="请输入文件哈希值"></el-input>
            </el-form-item>
        </el-form>
        <div slot="footer" class="dialog-footer">
            <el-button @click="quickVerifyVisible = false">取消</el-button>
            <el-button type="primary" @click="doQuickVerify">验证</el-button>
        </div>
    </el-dialog>

    <!-- 用户信息对话框 -->
    <el-dialog title="用户信息" :visible.sync="userInfoVisible" width="40%">
        <el-descriptions :column="1" v-if="userInfo" border>
            <el-descriptions-item label="用户名">{{ userInfo.username }}</el-descriptions-item>
            <el-descriptions-item label="真实姓名">{{ userInfo.realName || '未设置' }}</el-descriptions-item>
            <el-descriptions-item label="邮箱">{{ userInfo.email || '未设置' }}</el-descriptions-item>
            <el-descriptions-item label="登录时间">{{ new Date().toLocaleString() }}</el-descriptions-item>
        </el-descriptions>
        <div slot="footer" class="dialog-footer">
            <el-button @click="userInfoVisible = false">关闭</el-button>
        </div>
    </el-dialog>

    <!-- 创建分组对话框 -->
    <el-dialog title="新建分组" :visible.sync="createGroupDialogVisible" width="500px" :before-close="handleCreateGroupClose">
        <el-form :model="createGroupForm" :rules="createGroupRules" ref="createGroupForm" label-width="100px">
            <el-form-item label="分组名称" prop="groupName">
                <el-input v-model="createGroupForm.groupName" placeholder="请输入分组名称" @input="onGroupNameChange"></el-input>
            </el-form-item>
            <el-form-item label="分组代码" prop="groupCode">
                <el-input v-model="createGroupForm.groupCode" placeholder="系统自动生成或手动输入">
                    <el-button slot="append" @click="generateGroupCode">自动生成</el-button>
                </el-input>
                <div style="font-size: 12px; color: #909399; margin-top: 5px;">
                    分组代码用于唯一标识，建议使用大写字母和数字
                </div>
            </el-form-item>
            <el-form-item label="描述信息">
                <el-input type="textarea" v-model="createGroupForm.description" placeholder="可选：输入分组描述信息" :autosize="{ minRows: 3, maxRows: 6 }"></el-input>
            </el-form-item>
        </el-form>
        <div slot="footer" class="dialog-footer">
            <el-button @click="handleCreateGroupClose">取 消</el-button>
            <el-button type="primary" :loading="createGroupLoading" @click="handleCreateGroup">
                <i class="el-icon-check"></i> 创建分组
            </el-button>
        </div>
    </el-dialog>

    <!-- 创建项目对话框 -->
    <el-dialog title="新建项目" :visible.sync="createProjectDialogVisible" width="500px" :before-close="handleCreateProjectClose">
        <el-form :model="createProjectForm" :rules="createProjectRules" ref="createProjectForm" label-width="100px">
            <el-form-item label="所属分组" prop="groupId">
                <el-select v-model="createProjectForm.groupId" placeholder="请选择所属分组" style="width: 100%;">
                    <el-option v-for="group in userGroups" :key="group.id" :label="group.groupName" :value="group.id">
                        <span style="float: left">{{ group.groupName }}</span>
                        <span style="float: right; color: #8492a6; font-size: 13px">{{ group.groupCode }}</span>
                    </el-option>
                </el-select>
            </el-form-item>
            <el-form-item label="项目名称" prop="projectName">
                <el-input v-model="createProjectForm.projectName" placeholder="请输入项目名称" @input="onProjectNameChange"></el-input>
            </el-form-item>
            <el-form-item label="项目代码" prop="projectCode">
                <el-input v-model="createProjectForm.projectCode" placeholder="系统自动生成或手动输入">
                    <el-button slot="append" @click="generateProjectCode">自动生成</el-button>
                </el-input>
                <div style="font-size: 12px; color: #909399; margin-top: 5px;">
                    项目代码在同一分组内唯一，建议使用大写字母和数字
                </div>
            </el-form-item>
            <el-form-item label="描述信息">
                <el-input type="textarea" v-model="createProjectForm.description" placeholder="可选：输入项目描述信息" :autosize="{ minRows: 3, maxRows: 6 }"></el-input>
            </el-form-item>
        </el-form>
        <div slot="footer" class="dialog-footer">
            <el-button @click="handleCreateProjectClose">取 消</el-button>
            <el-button type="primary" :loading="createProjectLoading" @click="handleCreateProject">
                <i class="el-icon-check"></i> 创建项目
            </el-button>
        </div>
    </el-dialog>

    <!-- 编辑分组对话框 -->
    <el-dialog title="编辑分组" :visible.sync="editGroupDialogVisible" width="500px">
        <el-form :model="editGroupForm" :rules="editGroupRules" ref="editGroupForm" label-width="100px">
            <el-form-item label="分组名称" prop="groupName">
                <el-input v-model="editGroupForm.groupName" placeholder="请输入分组名称"></el-input>
            </el-form-item>
            <el-form-item label="分组代码">
                <el-input v-model="editGroupForm.groupCode" disabled placeholder="分组代码不可修改"></el-input>
            </el-form-item>
            <el-form-item label="描述信息">
                <el-input type="textarea" v-model="editGroupForm.description" placeholder="可选：输入分组描述信息" :autosize="{ minRows: 3, maxRows: 6 }"></el-input>
            </el-form-item>
        </el-form>
        <div slot="footer" class="dialog-footer">
            <el-button @click="editGroupDialogVisible = false">取 消</el-button>
            <el-button type="primary" :loading="editGroupLoading" @click="handleEditGroup">
                <i class="el-icon-check"></i> 更新分组
            </el-button>
        </div>
    </el-dialog>

    <!-- 编辑项目对话框 -->
    <el-dialog title="编辑项目" :visible.sync="editProjectDialogVisible" width="500px">
        <el-form :model="editProjectForm" :rules="editProjectRules" ref="editProjectForm" label-width="100px">
            <el-form-item label="项目名称" prop="projectName">
                <el-input v-model="editProjectForm.projectName" placeholder="请输入项目名称"></el-input>
            </el-form-item>
            <el-form-item label="项目代码">
                <el-input v-model="editProjectForm.projectCode" disabled placeholder="项目代码不可修改"></el-input>
            </el-form-item>
            <el-form-item label="描述信息">
                <el-input type="textarea" v-model="editProjectForm.description" placeholder="可选：输入项目描述信息" :autosize="{ minRows: 3, maxRows: 6 }"></el-input>
            </el-form-item>
        </el-form>
        <div slot="footer" class="dialog-footer">
            <el-button @click="editProjectDialogVisible = false">取 消</el-button>
            <el-button type="primary" :loading="editProjectLoading" @click="handleEditProject">
                <i class="el-icon-check"></i> 更新项目
            </el-button>
        </div>
    </el-dialog>

    <!-- 文件存证详情对话框 -->
    <el-dialog title="文件存证详情" :visible.sync="fileEvidenceDetailDialogVisible" width="70%">
        <div v-if="currentFileEvidence">
            <el-descriptions :column="2" border>
                <el-descriptions-item label="文件名">{{ currentFileEvidence.fileName }}</el-descriptions-item>
                <el-descriptions-item label="文件大小">{{ formatFileSize(currentFileEvidence.fileSize) }}</el-descriptions-item>
                <el-descriptions-item label="文件哈希">{{ currentFileEvidence.fileHash }}</el-descriptions-item>
                <el-descriptions-item label="哈希算法">{{ currentFileEvidence.hashAlgorithm }}</el-descriptions-item>
                <el-descriptions-item label="上链状态">
                    <el-tag :type="getChainStatusType(currentFileEvidence.chainStatus)" size="small">
                        {{ getChainStatusText(currentFileEvidence.chainStatus) }}
                    </el-tag>
                </el-descriptions-item>
                <el-descriptions-item label="交易哈希">{{ currentFileEvidence.transactionHash || '未上链' }}</el-descriptions-item>
                <el-descriptions-item label="区块号">{{ currentFileEvidence.blockNumber || '未上链' }}</el-descriptions-item>
                <el-descriptions-item label="合约地址">{{ currentFileEvidence.contractAddress || '未知' }}</el-descriptions-item>
                <el-descriptions-item label="上传时间">{{ formatDateTime(currentFileEvidence.createdAt) }}</el-descriptions-item>
                <el-descriptions-item label="更新时间">{{ formatDateTime(currentFileEvidence.updatedAt) }}</el-descriptions-item>
                <el-descriptions-item label="描述信息" span="2">{{ currentFileEvidence.description || '无' }}</el-descriptions-item>
                <el-descriptions-item label="提交信息" span="2">{{ currentFileEvidence.commitMessage || '无' }}</el-descriptions-item>
            </el-descriptions>
        </div>
        <div slot="footer" class="dialog-footer">
            <el-button @click="fileEvidenceDetailDialogVisible = false">关闭</el-button>
            <el-button type="primary" @click="verifyFileEvidence(currentFileEvidence.fileHash)" v-if="currentFileEvidence">验证存证</el-button>
        </div>
    </el-dialog>
    </el-container>

    <!-- 主题切换按钮 -->
    <el-button class="theme-switch" circle @click="toggleTheme">
        <i :class="isDarkTheme ? 'el-icon-sunny' : 'el-icon-moon'"></i>
    </el-button>
</div>

<!-- JavaScript依赖 -->
<script src="https://cdn.bootcdn.net/ajax/libs/vue/2.6.14/vue.js"></script>
<script src="https://cdn.bootcdn.net/ajax/libs/element-ui/2.15.14/index.min.js"></script>
<script src="https://cdn.bootcdn.net/ajax/libs/axios/0.24.0/axios.min.js"></script>

<!-- 应用脚本 -->
<script>
    // 简单测试Vue是否正常工作
    
    // Vue应用实例
    new Vue({
        el: '#app',
        data() {
            return {
                // 调试模式
                debugMode: false,
                debugInfo: {
                    hasToken: '检查中...',
                    hasUserInfo: '检查中...'
                },
                
                // 用户相关
                userInfo: null,
                userInfoVisible: false,

                // 主题
                isDarkTheme: false,

                // 登录表单
                loginForm: {
                    username: '',
                    password: ''
                },
                loginRules: {
                    username: [
                        { required: true, message: '请输入用户名', trigger: 'blur' },
                        { min: 3, max: 50, message: '用户名长度在 3 到 50 个字符', trigger: 'blur' }
                    ],
                    password: [
                        { required: true, message: '请输入密码', trigger: 'blur' },
                        { min: 6, message: '密码长度至少 6 个字符', trigger: 'blur' }
                    ]
                },
                loginLoading: false,

                // 注册相关
                showRegister: false,
                registerForm: {
                    username: '',
                    password: '',
                    confirmPassword: '',
                    realName: '',
                    email: ''
                },
                registerRules: {
                    username: [
                        { required: true, message: '请输入用户名', trigger: 'blur' },
                        { min: 2, max: 30, message: '用户名长度在 2 到 30 个字符', trigger: 'blur' },
                        { pattern: /^[a-zA-Z0-9_\-\u4e00-\u9fa5]+$/, message: '用户名只能包含字母、数字、下划线、中划线和中文', trigger: 'blur' }
                    ],
                    password: [
                        { required: true, message: '请输入密码', trigger: 'blur' },
                        { min: 6, max: 20, message: '密码长度在 6 到 20 个字符', trigger: 'blur' }
                    ],
                    confirmPassword: [
                        { required: true, message: '请确认密码', trigger: 'blur' },
                        { validator: (rule, value, callback) => {
                            if (value !== this.registerForm.password) {
                                callback(new Error('两次输入的密码不一致'));
                            } else {
                                callback();
                            }
                        }, trigger: 'blur' }
                    ],
                    realName: [
                        { required: true, message: '请输入真实姓名', trigger: 'blur' },
                        { min: 2, max: 30, message: '真实姓名长度在 2 到 30 个字符', trigger: 'blur' }
                    ],
                    email: [
                        { type: 'email', message: '请输入正确的邮箱地址', trigger: 'blur' }
                    ]
                },
                registerLoading: false,

                // 导航相关
                activeIndex: '1',
                activeTab: 'upload',

                // 上传相关
                uploadAction: '/api/evidence/upload',
                uploadHeaders: {},
                uploadData: {
                    description: '',
                    hashAlgorithm: 'SHA256'
                },
                fileList: [],
                uploadLoading: false,
                uploadProgress: 0,
                uploadStatus: null,
                progressText: '准备上传...',
                textContent: '',  // 文字内容存证
                recentUploads: [],
                recentLoading: false,

                // 查询相关
                queryForm: {
                    fileName: '',
                    fileHash: '',
                    transactionHash: '',
                    blockNumber: '',
                    chainStatus: null,
                    current: 1,
                    size: 10
                },
                dateRange: null,

                // 表格数据
                evidenceList: [],
                tableLoading: false,

                // 分页
                pagination: {
                    current: 1,
                    size: 10,
                    total: 0
                },

                // 对话框
                detailDialogVisible: false,
                selectedEvidence: null,
                quickVerifyVisible: false,
                quickVerifyHash: '',

                // 区块链信息
                blockchainInfo: {
                    blockNumber: 0,
                    connected: false,
                    groupId: 'group0'
                },
                contractAddress: '',
                statistics: {
                    totalFiles: 0,
                    todayFiles: 0,
                    successRate: '0%'
                },
                searchType: 'block',
                searchValue: '',
                blockchainSearchResult: null,

                // 代码存证相关
                // 加载状态
                codeLoading: {
                    createRepo: false,
                    createBranch: false,
                    upload: false,
                    table: false,
                    merge: false
                },
                // 拖拽状态
                isDragOver: false,
                // 仓库表单
                repositoryForm: {
                    groupName: '',
                    projectName: '',
                    description: ''
                },
                // 表单验证规则
                repositoryRules: {
                    groupName: [
                        { required: true, message: '请输入分组名称', trigger: 'blur' },
                        { pattern: /^[a-zA-Z0-9_-]+$/, message: '只能包含字母、数字、下划线和连字符', trigger: 'blur' },
                        { min: 2, max: 50, message: '长度在 2 到 50 个字符', trigger: 'blur' }
                    ],
                    projectName: [
                        { required: true, message: '请输入项目名称', trigger: 'blur' },
                        { pattern: /^[a-zA-Z0-9_-]+$/, message: '只能包含字母、数字、下划线和连字符', trigger: 'blur' },
                        { min: 2, max: 50, message: '长度在 2 到 50 个字符', trigger: 'blur' }
                    ]
                },
                // 分支表单
                branchForm: {
                    branchName: '',
                    baseBranch: ''
                },
                // 分支合并表单
                mergeForm: {
                    sourceBranch: '',
                    targetBranch: ''
                },
                // 上传表单
                uploadForm: {
                    repositoryId: '',
                    branchName: 'main',
                    commitMessage: '',
                    uploadMode: 'single'
                },
                // Tab激活状态
                branchTabActive: 'create',
                // 代码存证数据列表
                repositories: [],
                branches: [],
                codeFileList: [],
                selectedRepository: '',
                codeEvidenceList: [],  // 代码存证列表（与查询验证的evidenceList分开）
                // 代码存证统计信息
                stats: {
                    totalRepositories: 0,
                    totalBranches: 0,
                    totalCommits: 0,
                    todayCommits: 0
                },

                // 文件存证管理相关数据
                fileEvidenceActiveView: 'upload',
                
                // 分组管理
                userGroups: [],
                groupList: [],
                groupListLoading: false,
                groupSearchKeyword: '',
                groupPagination: {
                    current: 1,
                    size: 10,
                    total: 0
                },
                createGroupDialogVisible: false,
                createGroupLoading: false,
                createGroupForm: {
                    groupName: '',
                    groupCode: '',
                    description: ''
                },
                createGroupRules: {
                    groupName: [
                        { required: true, message: '请输入分组名称', trigger: 'blur' },
                        { min: 2, max: 100, message: '长度在 2 到 100 个字符', trigger: 'blur' }
                    ]
                },
                editGroupDialogVisible: false,
                editGroupLoading: false,
                editGroupForm: {
                    id: null,
                    groupName: '',
                    groupCode: '',
                    description: ''
                },
                editGroupRules: {
                    groupName: [
                        { required: true, message: '请输入分组名称', trigger: 'blur' },
                        { min: 2, max: 100, message: '长度在 2 到 100 个字符', trigger: 'blur' }
                    ]
                },
                
                // 项目管理
                userProjects: [],
                currentProjects: [],
                projectList: [],
                projectListLoading: false,
                projectSearchKeyword: '',
                projectFilterGroupId: null,
                projectPagination: {
                    current: 1,
                    size: 10,
                    total: 0
                },
                createProjectDialogVisible: false,
                createProjectLoading: false,
                createProjectForm: {
                    groupId: null,
                    projectName: '',
                    projectCode: '',
                    description: ''
                },
                createProjectRules: {
                    groupId: [
                        { required: true, message: '请选择所属分组', trigger: 'change' }
                    ],
                    projectName: [
                        { required: true, message: '请输入项目名称', trigger: 'blur' },
                        { min: 2, max: 100, message: '长度在 2 到 100 个字符', trigger: 'blur' }
                    ]
                },
                editProjectDialogVisible: false,
                editProjectLoading: false,
                editProjectForm: {
                    id: null,
                    projectName: '',
                    projectCode: '',
                    description: ''
                },
                editProjectRules: {
                    projectName: [
                        { required: true, message: '请输入项目名称', trigger: 'blur' },
                        { min: 2, max: 100, message: '长度在 2 到 100 个字符', trigger: 'blur' }
                    ]
                },
                
                // 文件存证上传
                selectedGroupId: null,
                selectedProjectId: null,
                fileEvidenceUploadAction: '/api/file-evidence/upload',
                fileEvidenceBatchUploadAction: '/api/file-evidence/upload-batch',
                fileEvidenceFileList: [],
                fileEvidenceBatchFileList: [],
                fileEvidenceHashAlgorithm: 'SHA256',
                fileEvidenceDescription: '',
                batchCommitMessage: '',
                fileEvidenceUploadData: {},
                fileEvidenceBatchUploadData: {},
                
                // 文件列表
                fileEvidenceList: [],
                fileEvidenceListLoading: false,
                fileSearchKeyword: '',
                fileFilterProjectId: null,
                fileFilterGroupId: null,
                fileFilterTimeRange: null,
                fileEvidencePagination: {
                    current: 1,
                    size: 10,
                    total: 0
                },
                fileEvidenceDetailDialogVisible: false,
                currentFileEvidence: null,
                
                // 操作日志
                operationLogList: [],
                operationLogListLoading: false,
                logFilterOperationType: '',
                logPagination: {
                    current: 1,
                    size: 20,
                    total: 0
                },
                
                // 统计信息
                fileEvidenceStats: {
                    totalGroups: 0,
                    totalProjects: 0,
                    totalFiles: 0,
                    todayFiles: 0
                }
            }
        },

        computed: {
            pageTitle() {
                const titles = {
                    'upload': '文件存证',
                    'code': '代码存证',
                    'query': '查询验证',
                    'blockchain': '区块链信息'
                };
                return titles[this.activeTab] || '区块链存证系统';
            },
            
            // 是否有文件
            hasFile() {
                return this.fileList.length > 0;
            },
            
            // 是否有文字内容
            hasTextContent() {
                return this.textContent && this.textContent.trim().length > 0;
            },
            
            // 是否可以上传
            canUpload() {
                return (this.hasFile || this.hasTextContent) && !this.uploadLoading;
            },
            
            // 当前文件信息
            currentFile() {
                return this.fileList.length > 0 ? this.fileList[0] : {};
            },
            
            // 文件存证管理相关computed
            canUploadFileEvidence() {
                return this.selectedProjectId && 
                       (this.fileEvidenceFileList.length > 0 || this.fileEvidenceBatchFileList.length > 0);
            }
        },

        watch: {
            activeTab(newVal) {
                const indexMap = {
                    'upload': '1',
                    'code': '2',
                    'query': '3',
                    'blockchain': '4'
                };
                this.activeIndex = indexMap[newVal] || '1';
                document.title = this.pageTitle;
            },

            dateRange(newVal) {
                if (newVal && newVal.length === 2) {
                    this.queryForm.startDate = this.formatDateForQuery(newVal[0]);
                    this.queryForm.endDate = this.formatDateForQuery(newVal[1]);
                } else {
                    this.queryForm.startDate = '';
                    this.queryForm.endDate = '';
                }
            },
            
            // 文件搜索相关的监听器
            fileFilterProjectId() {
                if (this.fileEvidenceActiveView === 'files') {
                    this.fileEvidencePagination.current = 1;
                    this.loadFileEvidenceList();
                }
            },
            
            fileFilterGroupId() {
                if (this.fileEvidenceActiveView === 'files') {
                    this.fileEvidencePagination.current = 1;
                    this.loadFileEvidenceList();
                }
            },
            
            fileFilterTimeRange() {
                if (this.fileEvidenceActiveView === 'files') {
                    this.fileEvidencePagination.current = 1;
                    this.loadFileEvidenceList();
                }
            }
        },

        created() {
            this.updateDebugInfo();
            this.initializeApp();
        },

        mounted() {
            document.title = this.pageTitle;
            this.initTheme();
            
            // 添加Vue错误处理
            this.$nextTick(() => {
                console.log('Vue实例挂载完成');
            });
        },
        
        errorCaptured(err, vm, info) {
            console.error('Vue组件错误:', err);
            console.error('错误信息:', info);
            return false;
        },

        methods: {
            // 更新调试信息
            updateDebugInfo() {
                this.debugInfo.hasToken = localStorage.getItem('token') ? '存在' : '不存在';
                this.debugInfo.hasUserInfo = localStorage.getItem('userInfo') ? '存在' : '不存在';
            },

            // 初始化应用
            initializeApp() {
                this.setupAxios();
                this.checkLogin();
                this.loadInitialData();
            },

            // 设置axios拦截器
            setupAxios() {
                axios.defaults.baseURL = '';
                axios.defaults.timeout = 30000;

                axios.interceptors.request.use(config => {
                    const token = localStorage.getItem('token');
                    if (token) {
                        config.headers.Authorization = `Bearer ${token}`;
                        this.uploadHeaders.Authorization = `Bearer ${token}`;
                    }
                    return config;
                });

                axios.interceptors.response.use(
                    response => {
                        const data = response.data;
                        if (data.code !== 200) {
                            this.$message.error(data.message || '操作失败');
                            return Promise.reject(data);
                        }
                        return data.data;
                    },
                    error => {
                        if (error.response?.status === 401) {
                            this.handleUnauthorized();
                        } else {
                            this.$message.error(error.response?.data?.message || '网络错误');
                        }
                        return Promise.reject(error);
                    }
                );
            },

            // 检查登录状态
            checkLogin() {
                const token = localStorage.getItem('token');
                const userInfo = localStorage.getItem('userInfo');

                if (token && userInfo) {
                    try {
                        const parsedUserInfo = JSON.parse(userInfo);
                        
                        // 验证用户信息的完整性
                        if (parsedUserInfo && parsedUserInfo.username && parsedUserInfo.id) {
                            this.userInfo = parsedUserInfo;
                            this.updateDebugInfo();
                            
                            // 显示自动登录提示
                            this.$message({
                                message: `欢迎回来，${parsedUserInfo.realName || parsedUserInfo.username}！`,
                                type: 'success',
                                duration: 2000
                            });
                            
                            this.loadInitialData();
                        } else {
                            throw new Error('用户信息格式错误');
                        }
                    } catch (e) {
                        // 清除无效的登录信息
                        localStorage.removeItem('token');
                        localStorage.removeItem('userInfo');
                        this.$message.warning('登录信息已过期，请重新登录');
                    }
                } else {
                    // 没有登录信息时显示提示
                    this.$message({
                        message: '请登录以使用区块链存证系统',
                        type: 'info',
                        duration: 3000
                    });
                }
            },

            // 加载初始数据
            loadInitialData() {
                if (this.userInfo) {
                    console.log('开始加载初始数据...');
                    Promise.all([
                        this.loadEvidenceList(),
                        this.refreshBlockchainInfo(),
                        this.loadStatistics(),
                        this.loadRecentUploads(),
                        this.loadRepositories(),  // 添加仓库数据加载
                        this.loadCodeEvidenceList(),  // 添加代码存证记录加载
                        this.loadFileEvidenceInitialData()  // 添加文件存证初始数据加载
                    ]).then(() => {
                        console.log('初始数据加载完成');
                        // 确保数据加载后触发视图更新
                        this.$nextTick(() => {
                            this.$forceUpdate();
                        });
                    }).catch(error => {
                        console.error('加载初始数据失败:', error);
                    });
                } else {
                    console.log('用户未登录，跳过初始数据加载');
                }
            },

            // 用户登录
            handleLogin() {
                this.$refs.loginForm.validate(valid => {
                    if (!valid) {
                        this.$message.warning('请检查输入信息');
                        return;
                    }

                    // 基础验证
                    if (!this.loginForm.username.trim() || !this.loginForm.password) {
                        this.$message.warning('请输入用户名和密码');
                        return;
                    }

                    this.loginLoading = true;
                    const startTime = Date.now();

                    axios.post('/api/auth/login', this.loginForm)
                        .then(data => {
                            // 注意：由于axios拦截器的处理，这里的data就是用户信息，不需要再访问data.data
                            if (!data || !data.token) {
                                throw new Error('登录响应数据格式错误');
                            }

                            // 保存登录信息
                            localStorage.setItem('token', data.token);
                            localStorage.setItem('userInfo', JSON.stringify(data));
                            
                            this.userInfo = data;
                            this.updateDebugInfo();
                            
                            // 显示欢迎信息
                            this.$notify({
                                title: '登录成功',
                                message: `欢迎回来，${data.realName || data.username}！`,
                                type: 'success',
                                duration: 3000
                            });

                            // 加载初始数据
                            this.loadInitialData();
                            this.resetLoginForm();
                        })
                        .catch(error => {
                            console.error('登录失败:', error);
                            
                            // 详细的错误处理
                            let errorMessage = '登录失败';
                            if (error.response) {
                                // 服务器响应错误
                                const status = error.response.status;
                                const data = error.response.data;
                                
                                if (status === 401) {
                                    errorMessage = '用户名或密码错误';
                                } else if (status === 403) {
                                    errorMessage = '账号被禁用，请联系管理员';
                                } else if (status === 500) {
                                    errorMessage = '服务器内部错误，请稍后重试';
                                } else if (data && data.message) {
                                    errorMessage = data.message;
                                }
                            } else if (error.request) {
                                // 网络错误
                                errorMessage = '网络连接失败，请检查网络状态';
                            } else if (error.message) {
                                errorMessage = error.message;
                            }

                            this.$message.error(errorMessage);
                        })
                        .finally(() => {
                            this.loginLoading = false;
                            
                            // 确保最小加载时间，避免闪烁
                            const elapsed = Date.now() - startTime;
                            const minTime = 500; // 最少显示500ms
                            if (elapsed < minTime) {
                                setTimeout(() => {
                                    this.loginLoading = false;
                                }, minTime - elapsed);
                            }
                        });
                });
            },

            // 处理注册
            handleRegister() {
                this.$refs.registerForm.validate(valid => {
                    if (!valid) {
                        this.$message.warning('请检查输入信息');
                        return;
                    }

                    // 确认密码一致性验证
                    if (this.registerForm.password !== this.registerForm.confirmPassword) {
                        this.$message.error('两次输入的密码不一致');
                        return;
                    }

                    this.registerLoading = true;

                    axios.post('/api/auth/register', this.registerForm)
                        .then(response => {
                            // 注意：由于axios拦截器处理，response就是后端返回的data部分
                            this.$message.success('注册成功！');
                            
                            // 显示DID信息
                            this.$alert(
                                `您的DID是：${response.did}\n\n` +
                                `请妥善保存此DID，您可以使用用户名或DID进行登录。`,
                                    '注册成功',
                                    {
                                        confirmButtonText: '确定',
                                        type: 'success',
                                        beforeClose: (action, instance, done) => {
                                            done();
                                            // 关闭注册对话框并自动填入登录信息
                                            this.showRegister = false;
                                            this.loginForm.username = this.registerForm.username;
                                            this.resetRegisterForm();
                                        }
                                    }
                                );
                            // 由于axios拦截器已经处理了错误情况，成功到达这里说明注册成功
                            // 不需要else分支
                        })
                        .catch(error => {
                            console.error('注册请求失败：', error);
                            let errorMessage = '注册失败，请稍后重试';
                            
                            if (error.response) {
                                if (error.response.data && error.response.data.message) {
                                    errorMessage = error.response.data.message;
                                } else if (error.response.status === 400) {
                                    errorMessage = '输入信息有误，请检查后重试';
                                } else if (error.response.status === 409) {
                                    errorMessage = '用户名或邮箱已存在';
                                } else if (error.response.status >= 500) {
                                    errorMessage = '服务器内部错误，请稍后重试';
                                }
                            }

                            this.$message.error(errorMessage);
                        })
                        .finally(() => {
                            this.registerLoading = false;
                        });
                });
            },

            // 关闭注册对话框
            handleRegisterClose() {
                this.showRegister = false;
                this.resetRegisterForm();
            },

            // 重置注册表单
            resetRegisterForm() {
                this.registerForm = {
                    username: '',
                    password: '',
                    confirmPassword: '',
                    realName: '',
                    email: ''
                };
                if (this.$refs.registerForm) {
                    this.$refs.registerForm.resetFields();
                }
            },

            // 处理菜单选择
            handleMenuSelect(key) {
                const tabMap = {
                    '1': 'upload',
                    '2': 'code',
                    '3': 'query',
                    '4': 'blockchain'
                };
                this.activeTab = tabMap[key] || 'upload';
                this.activeIndex = key;
                
                this.loadTabData(this.activeTab);
            },
            
            // 快速切换Tab
            quickSwitchTab(tabName) {
                console.log(`开始切换到${tabName}模块`);
                
                const indexMap = {
                    'upload': '1',
                    'code': '2',
                    'query': '3',
                    'blockchain': '4'
                };
                
                // 确保用户已登录
                if (!this.userInfo) {
                    this.$message.warning('请先登录');
                    return;
                }
                
                this.activeTab = tabName;
                this.activeIndex = indexMap[tabName] || '1';
                
                // 立即验证tab切换
                console.log('切换前 activeTab:', this.activeTab);
                console.log('切换前 activeIndex:', this.activeIndex);
                
                // 等待DOM更新后加载数据
                this.$nextTick(() => {
                    console.log('切换后 activeTab:', this.activeTab);
                    console.log('切换后 activeIndex:', this.activeIndex);
                    
                    setTimeout(() => {
                        console.log(`DOM更新完成，开始加载${tabName}模块数据`);
                        this.loadTabData(tabName);
                        
                        // 双重确保视图更新
                        setTimeout(() => {
                            this.$forceUpdate();
                            console.log(`${tabName}模块强制更新完成`);
                            
                            // 验证数据状态
                            if (tabName === 'code') {
                                console.log('代码存证数据状态:');
                                console.log('repositories:', this.repositories);
                                console.log('codeEvidenceList:', this.codeEvidenceList);
                            }
                        }, 200);
                    }, 100);
                });
                
                // 显示切换提示
                const tabNames = {
                    'upload': '文件存证',
                    'code': '代码存证',
                    'query': '查询验证',
                    'blockchain': '区块链信息'
                };
                this.$message.success(`已切换到${tabNames[tabName]}模块`);
            },
            
            // 获取模块名称
            getModuleName(tabName) {
                const moduleNames = {
                    'upload': '文件存证',
                    'code': '代码存证',
                    'query': '查询验证',
                    'blockchain': '区块链信息'
                };
                return moduleNames[tabName] || '文件存证';
            },
            
            // 加载Tab数据
            loadTabData(tabName) {
                console.log(`开始加载${tabName}模块数据`);
                
                // 确保数据初始化
                if (tabName === 'code') {
                    // 初始化代码存证相关数据
                    if (!this.repositories) this.repositories = [];
                    if (!this.branches) this.branches = [];
                    if (!this.codeEvidenceList) this.codeEvidenceList = [];
                    if (!this.codeFileList) this.codeFileList = [];
                }
                
                // 根据切换的tab加载相应数据
                switch(tabName) {
                    case 'code':
                        this.loadRepositories();
                        this.loadCodeEvidenceList();
                        this.loadStats();
                        break;
                    case 'query':
                        this.loadEvidenceList();
                        this.loadStatistics();
                        break;
                    case 'blockchain':
                        this.refreshBlockchainInfo();
                        this.loadStatistics();
                        break;
                    case 'upload':
                        this.loadRecentUploads();
                        this.loadStatistics();
                        break;
                }
            },

            // 提交上传
            submitUpload() {
                if (!this.canUpload) {
                    this.$message.warning('请先选择文件或输入文字内容');
                    return;
                }

                this.uploadLoading = true;
                this.uploadProgress = 0;
                this.uploadStatus = null;

                // 判断是文件上传还是文字内容上传
                if (this.hasFile) {
                    // 文件上传
                    this.progressText = '开始上传文件...';
                    this.$refs.upload.submit();
                } else if (this.hasTextContent) {
                    // 文字内容上传
                    this.progressText = '开始上传文字内容...';
                    this.submitTextContent();
                }
            },

            // 上传前检查
            beforeUpload(file) {
                
                const isLt100M = file.size / 1024 / 1024 < 100;
                if (!isLt100M) {
                    this.$message.error('文件大小不能超过100MB');
                    return false;
                }

                // 支持的MIME类型
                const allowedMime = new Set([
                    // 文档类
                    'application/pdf', 'application/msword', 
                    'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
                    'application/vnd.ms-excel', 
                    'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                    'application/rtf', 'text/plain', 'text/csv',
                    'application/vnd.ms-powerpoint',
                    'application/vnd.openxmlformats-officedocument.presentationml.presentation',
                    
                    // 图片类
                    'image/jpeg', 'image/jpg', 'image/png', 'image/gif', 'image/bmp', 
                    'image/tiff', 'image/webp', 'image/svg+xml',
                    
                    // 压缩包类
                    'application/zip', 'application/x-rar-compressed', 
                    'application/x-7z-compressed', 'application/x-tar', 'application/gzip',
                    
                    // 代码脚本类
                    'text/x-python-script', 'text/x-java-source', 'text/x-c', 'text/x-c++src',
                    'application/javascript', 'text/javascript', 'application/json',
                    'text/html', 'text/css', 'text/xml', 'application/xml',
                    'text/x-sql', 'text/x-sh', 'application/x-python-code',
                    'application/octet-stream'
                ]);
                
                // 支持的扩展名（兜底验证）
                const allowedExt = new Set([
                    // 文档类
                    'pdf','doc','docx','xls','xlsx','ppt','pptx','rtf','txt','csv',
                    // 图片类
                    'jpg','jpeg','png','gif','bmp','tiff','tif','webp','svg',
                    // 压缩包类
                    'zip','rar','7z','tar','gz',
                    // 代码脚本类
                    'py','java','c','cpp','cxx','cc','h','hpp','js','json','html','htm',
                    'css','xml','sql','sh','bash','sol','ts','jsx','tsx','vue','php',
                    'rb','go','rs','swift','kt','scala','pl','r','m','mat','pyc'
                ]);
                const typeOk = file.type ? allowedMime.has(file.type) : true;
                const ext = (file.name.split('.').pop() || '').toLowerCase();
                const extOk = allowedExt.has(ext);

                if (!typeOk && !extOk) {
                    this.$message.error('不支持的文件类型，支持：文档类(PDF、DOC、DOCX、XLS、XLSX、PPT、PPTX、RTF、TXT、CSV)、图片类(JPG、PNG、GIF、BMP、TIFF、WEBP、SVG)、压缩包类(ZIP、RAR、7Z、TAR、GZ)、代码脚本类(PY、JAVA、C、CPP、JS、HTML、CSS、XML、SQL、SOL等)');
                    return false;
                }

                return true;
            },

            // 上传进度处理
            handleUploadProgress(event, file, fileList) {
                this.uploadLoading = true;
                this.uploadProgress = Math.round(event.percent || 0);
                this.uploadStatus = null;
                this.progressText = `已上传 ${this.uploadProgress}%`;
            },

            // 文件变化处理
            handleFileChange(file, fileList) {
                this.fileList = fileList;
            },

            // 文件移除处理
            handleFileRemove(file, fileList) {
                this.fileList = fileList;
            },

            // 提交文字内容
            submitTextContent() {
                const formData = new FormData();
                
                // 将文字内容作为Blob添加到formData中
                const textBlob = new Blob([this.textContent], { type: 'text/plain' });
                const fileName = `text_content_${Date.now()}.txt`;
                formData.append('file', textBlob, fileName);
                
                // 添加其他参数
                formData.append('description', this.uploadData.description || '文字内容存证');
                formData.append('hashAlgorithm', this.uploadData.hashAlgorithm);
                formData.append('contentType', 'TEXT'); // 标识这是文字内容

                // 使用axios直接上传
                axios.post(this.uploadAction, formData, {
                    headers: {
                        'Content-Type': 'multipart/form-data',
                        ...this.uploadHeaders
                    },
                    onUploadProgress: (progressEvent) => {
                        this.uploadProgress = Math.round((progressEvent.loaded * 100) / progressEvent.total);
                        this.progressText = `文字内容上传中 ${this.uploadProgress}%`;
                    }
                })
                .then(response => {
                    // 直接传递完整的axios响应对象，保持与el-upload一致
                    this.handleUploadSuccess(response, null);
                })
                .catch(error => {
                    this.handleUploadError(error, null);
                });
            },

            // 清空文字内容
            clearTextContent() {
                this.textContent = '';
            },

            // 上传成功
            handleUploadSuccess(response, file) {
                
                this.uploadProgress = 100;
                this.uploadStatus = 'success';
                this.progressText = '上传成功！';
                
                // 统一处理响应格式
                let actualResponse = response;
                if (response && response.data) {
                    // 如果是axios响应，取data部分
                    actualResponse = response.data;
                } else {
                    // 如果是el-upload响应，直接使用response
                }
                
                const msg = (actualResponse && (actualResponse.message || actualResponse.msg)) || '文件上传成功！';
                this.$message.success(msg);

                setTimeout(() => {
                    this.uploadLoading = false;
                    this.clearFiles();
                    this.clearTextContent();
                    this.uploadData.description = '';
                    
                    // 强制刷新数据，确保显示最新记录
                    this.loadEvidenceList();
                    this.loadRecentUploads();
                    this.loadStatistics();
                }, 1000); // 稍微延长等待时间，确保后端处理完成
            },

            // 上传失败
            handleUploadError(error, file) {
                this.uploadStatus = 'exception';
                this.progressText = '上传失败！';
                this.uploadLoading = false;
                
                const msg = (error && error.message) ? error.message : '文件上传失败，请重试';
                this.$message.error(msg);
            },

            // 清空文件
            clearFiles() {
                this.fileList = [];
                this.$refs.upload.clearFiles();
            },

            // 查询存证
            handleQuery() {
                this.pagination.current = 1;
                this.loadEvidenceList();
            },

            // 重置查询
            resetQuery() {
                this.queryForm = {
                    fileName: '',
                    fileHash: '',
                    transactionHash: '',
                    blockNumber: '',
                    chainStatus: null,
                    current: 1,
                    size: 10
                };
                this.dateRange = null;
                this.pagination.current = 1;
                this.loadEvidenceList();
            },

            // 加载存证列表
            loadEvidenceList() {
                if (!this.userInfo) {
                    console.log('用户未登录，无法加载数据');
                    return;
                }

                console.log('开始加载存证列表...');
                this.tableLoading = true;
                const params = {
                    ...this.queryForm,
                    current: this.pagination.current,
                    size: this.pagination.size
                };

                Object.keys(params).forEach(key => {
                    if (params[key] === '' || params[key] === null || params[key] === undefined) {
                        delete params[key];
                    }
                });

                console.log('查询验证参数:', params);
                axios.get('/api/evidence/list', { params })
                    .then(data => {
                        console.log('查询验证API响应:', data);
                        this.evidenceList = data.records || [];
                        this.pagination.total = data.total || 0;
                        console.log('查询验证模块加载数据成功:', this.evidenceList.length, '条');
                        console.log('查询验证数据:', this.evidenceList);
                        
                        // 强制触发Vue更新
                        this.$nextTick(() => {
                            this.$forceUpdate();
                        });
                    })
                    .catch(error => {
                        console.error('查询验证模块加载数据失败:', error);
                        this.evidenceList = [];
                        this.pagination.total = 0;
                        this.$message.error('加载数据失败，请检查网络连接');
                    })
                    .finally(() => {
                        this.tableLoading = false;
                    });
            },

            // 加载最近上传
            loadRecentUploads() {
                if (!this.userInfo) return;

                this.recentLoading = true;
                const params = { 
                    current: 1, 
                    size: 5,
                    _t: Date.now() // 添加时间戳防止缓存
                };

                axios.get('/api/evidence/list', { params })
                    .then(data => {
                        this.recentUploads = data.records || [];
                    })
                    .catch(error => {
                        console.error('加载最近上传记录失败:', error);
                    })
                    .finally(() => {
                        this.recentLoading = false;
                    });
            },

            // 查看详情
            viewDetail(row) {
                this.selectedEvidence = { ...row };
                this.detailDialogVisible = true;
            },

            // 验证存证
            verifyEvidence(fileHash) {
                if (!fileHash) {
                    this.$message.warning('文件哈希不能为空');
                    return;
                }

                const loading = this.$loading({
                    lock: true,
                    text: '正在验证存证...',
                    spinner: 'el-icon-loading',
                    background: 'rgba(0, 0, 0, 0.7)'
                });

                axios.post('/api/evidence/verify', null, {
                    params: { fileHash }
                }).then(data => {
                    if (data) {
                        this.$message.success('存证验证通过！文件确实存在于区块链上');
                    } else {
                        this.$message.warning('存证验证失败！文件可能不存在或已被篡改');
                    }
                }).finally(() => {
                    loading.close();
                });
            },

            // 分页处理
            handleSizeChange(size) {
                this.pagination.size = size;
                this.pagination.current = 1;
                this.loadEvidenceList();
            },

            handleCurrentChange(current) {
                this.pagination.current = current;
                this.loadEvidenceList();
            },

            // 工具方法
            formatFileSize(size) {
                if (!size || size === 0) return '0B';
                const units = ['B', 'KB', 'MB', 'GB', 'TB'];
                let index = 0;
                let fileSize = size;

                while (fileSize >= 1024 && index < units.length - 1) {
                    fileSize /= 1024;
                    index++;
                }

                return fileSize.toFixed(2) + units[index];
            },

            formatDate(date) {
                if (!date) return '';
                return new Date(date).toLocaleString('zh-CN');
            },

            formatDateForQuery(date) {
                if (!date) return '';
                return new Date(date).toISOString();
            },

            getStatusType(status) {
                const statusMap = {
                    0: 'warning',
                    1: 'success',
                    2: 'danger'
                };
                return statusMap[status] || 'info';
            },

            getStatusText(status) {
                const statusMap = {
                    0: '待上链',
                    1: '上链成功',
                    2: '上链失败'
                };
                return statusMap[status] || '未知状态';
            },

            copyToClipboard(text) {
                if (!text) return;

                if (navigator.clipboard) {
                    navigator.clipboard.writeText(text).then(() => {
                        this.$message.success('已复制到剪贴板');
                    });
                } else {
                    const textArea = document.createElement('textarea');
                    textArea.value = text;
                    textArea.style.position = 'fixed';
                    textArea.style.opacity = '0';
                    document.body.appendChild(textArea);
                    textArea.select();
                    document.execCommand('copy');
                    document.body.removeChild(textArea);
                    this.$message.success('已复制到剪贴板');
                }
            },

            // 主题切换
            initTheme() {
                const savedTheme = localStorage.getItem('theme');
                if (savedTheme === 'dark') {
                    this.isDarkTheme = true;
                    document.documentElement.setAttribute('data-theme', 'dark');
                }
            },

            toggleTheme() {
                this.isDarkTheme = !this.isDarkTheme;
                if (this.isDarkTheme) {
                    document.documentElement.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                } else {
                    document.documentElement.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                }
            },

            // 其他方法的简化实现...
            refreshRecentUploads() { this.loadRecentUploads(); },
            refreshData() { this.loadEvidenceList(); this.loadStatistics(); },
            exportData() { this.$message.info('导出功能开发中...'); },
            showQuickVerify() { this.quickVerifyVisible = true; this.quickVerifyHash = ''; },
            doQuickVerify() { this.verifyEvidence(this.quickVerifyHash.trim()); this.quickVerifyVisible = false; },
            showUserInfo() { this.userInfoVisible = true; },
            handleCloseDetail() { this.detailDialogVisible = false; this.selectedEvidence = null; },
            viewOnChain(row) { this.$alert(`交易哈希: ${row.transactionHash}\n区块号: ${row.blockNumber}`, '上链信息'); },
            // 刷新区块链信息
            async refreshBlockchainInfo() {
                if (!this.userInfo) {
                    console.log('用户未登录，无法获取区块链信息');
                    return;
                }
                
                try {
                    console.log('正在刷新区块链信息...');
                    const data = await axios.get('/api/blockchain/info');
                    console.log('区块链API响应:', data);
                    
                    // 由于axios拦截器处理，这里的data就是原来的data.data
                    // 使用Vue.set确保响应式更新
                    this.$set(this, 'blockchainInfo', {
                        blockNumber: data.blockNumber || 0,
                        connected: data.connected || false,
                        groupId: data.groupId || 'group1'
                    });
                    
                    this.$set(this, 'contractAddress', data.contractAddress || '未配置');
                    
                    console.log('区块链信息加载成功:', this.blockchainInfo);
                    console.log('合约地址:', this.contractAddress);
                    
                    // 强制触发Vue更新
                    this.$nextTick(() => {
                        this.$forceUpdate();
                    });
                    
                    if (data.connected) {
                        this.$message.success('区块链连接正常');
                    } else {
                        this.$message.warning('区块链连接异常: ' + (data.error || '未知错误'));
                    }
                } catch (error) {
                    console.error('获取区块链信息失赅:', error);
                    this.$set(this.blockchainInfo, 'connected', false);
                    this.$message.error('获取区块链信息失败');
                }
            },
            // 加载统计信息
            async loadStatistics() {
                try {
                    const data = await axios.get('/api/evidence/statistics');
                    // 由于axios拦截器处理，这里的data就是原来的data.data
                    this.statistics = {
                        totalFiles: data.totalFiles || 0,
                        todayFiles: data.todayFiles || 0,
                        successRate: data.successRate || '0%'
                    };
                } catch (error) {
                    console.error('获取统计信息失败:', error);
                    this.$message.error('获取统计信息失败');
                }
            },
            // 区块链搜索
            async searchBlockchain() {
                if (!this.searchValue.trim()) {
                    this.$message.warning('请输入查询值');
                    return;
                }

                try {
                    let data;
                    if (this.searchType === 'block') {
                        // 搜索区块信息
                        data = await axios.get(`/api/blockchain/block/${this.searchValue.trim()}`);
                    } else if (this.searchType === 'transaction') {
                        // 搜索交易信息
                        data = await axios.get(`/api/blockchain/transaction/${this.searchValue.trim()}`);
                    }

                    // 由于axios拦截器处理，能到达这里说明请求成功
                    this.blockchainSearchResult = {
                        type: this.searchType,
                        query: this.searchValue.trim(),
                        result: data
                    };
                    this.$message.success('查询成功');
                } catch (error) {
                    console.error('区块链搜索失败:', error);
                    this.blockchainSearchResult = null;
                    this.$message.error('查询失败，请检查输入值是否正确');
                }
            },
            // 快速填入测试账号
            fillTestAccount(username) {
                this.loginForm.username = username;
                this.loginForm.password = '123123';
                this.$message.success(`已填入${username}的测试账号信息`);
            },
            resetLoginForm() { 
                this.loginForm = { username: '', password: '' }; 
                if (this.$refs.loginForm) {
                    this.$refs.loginForm.resetFields();
                }
            },
            handleUnauthorized() { this.$message.error('登录已过期'); this.logout(); },

            // ========== 代码存证相关方法 ==========
            // 创建仓库
            async createRepository() {
                // 使用表单验证
                this.$refs.repositoryForm.validate((valid) => {
                    if (!valid) {
                        return false;
                    }
                });
                
                // 检查仓库是否已存在
                const exists = this.repositories.find(repo => 
                    repo.groupName === this.repositoryForm.groupName && 
                    repo.projectName === this.repositoryForm.projectName
                );
                if (exists) {
                    this.$message.error('仓库已存在');
                    return;
                }
                
                this.codeLoading.createRepo = true;
                try {
                    const response = await this.codeRequest('POST', '/api/code/repository', this.repositoryForm);
                    if (response.code === 200) {
                        this.$message.success('仓库创建成功');
                        this.repositoryForm = { groupName: '', projectName: '', description: '' };
                        this.loadRepositories();
                    } else {
                        this.$message.error(response.message || '创建失败');
                    }
                } catch (error) {
                    console.error('创建仓库失败:', error);
                    this.$message.error('创建失败：' + error.message);
                } finally {
                    this.codeLoading.createRepo = false;
                }
            },
            
            // 创建分支
            async createBranch() {
                if (!this.selectedRepository || !this.branchForm.branchName) {
                    this.$message.error('请选择仓库并填写分支名称');
                    return;
                }
                
                // 验证分支名称格式
                const branchRegex = /^[a-zA-Z0-9_/-]+$/;
                if (!branchRegex.test(this.branchForm.branchName)) {
                    this.$message.error('分支名称只能包含字母、数字、下划线、连字符和斜杠');
                    return;
                }
                
                // 检查分支是否已存在
                if (this.branches.find(b => b.branchName === this.branchForm.branchName)) {
                    this.$message.error('分支名称已存在');
                    return;
                }
                
                this.codeLoading.createBranch = true;
                try {
                    const params = {
                        repositoryId: this.selectedRepository,
                        branchName: this.branchForm.branchName,
                        baseBranch: this.branchForm.baseBranch || 'main'
                    };
                    
                    const response = await this.codeRequest('POST', '/api/code/branch', params);
                    if (response.code === 200) {
                        this.$message.success('分支创建成功');
                        this.branchForm = { branchName: '', baseBranch: '' };
                        this.loadBranches();
                    } else {
                        this.$message.error(response.message || '创建失败');
                    }
                } catch (error) {
                    console.error('创建分支失败:', error);
                    this.$message.error('创建失败：' + error.message);
                } finally {
                    this.codeLoading.createBranch = false;
                }
            },
            
            // 上传代码
            async uploadCode() {
                if (!this.uploadForm.repositoryId || !this.uploadForm.branchName || this.codeFileList.length === 0) {
                    this.$message.error('请选择仓库、分支并上传文件');
                    return;
                }
                
                if (!this.uploadForm.commitMessage) {
                    this.$message.error('请输入提交信息');
                    return;
                }
                
                // 验证文件类型
                const validExtensions = ['.py', '.java', '.js', '.ts', '.html', '.css', '.sql', '.json', '.xml', '.c', '.cpp', '.h', '.hpp', '.go', '.rs', '.php', '.rb', '.swift', '.kt', '.scala', '.sol', '.vue', '.jsx', '.tsx'];
                const invalidFiles = this.codeFileList.filter(file => {
                    const ext = '.' + file.name.split('.').pop().toLowerCase();
                    return !validExtensions.includes(ext);
                });
                
                if (invalidFiles.length > 0) {
                    this.$message.error(`不支持的文件类型: ${invalidFiles.map(f => f.name).join(', ')}`);
                    return;
                }
                
                // 验证文件大小
                const maxSize = 10 * 1024 * 1024; // 10MB
                const oversizedFiles = this.codeFileList.filter(file => file.size > maxSize);
                if (oversizedFiles.length > 0) {
                    this.$message.error(`文件过大(超过10MB): ${oversizedFiles.map(f => f.name).join(', ')}`);
                    return;
                }
                
                this.codeLoading.upload = true;
                
                try {
                    if (this.uploadForm.uploadMode === 'batch') {
                        // 批量上传模式
                        await this.uploadCodeBatch();
                    } else {
                        // 单文件上传模式
                        await this.uploadCodeSingle();
                    }
                } catch (error) {
                    console.error('上传代码失败:', error);
                    // 单文件上传模式的错误已在 handleUploadResult 中处理，避免重复显示
                    if (this.uploadForm.uploadMode === 'batch') {
                        // 批量上传的错误信息由 uploadCodeBatch 中已经显示了，这里不再重复
                        // this.$message.error('上传失败：' + error.message);
                    }
                } finally {
                    this.codeLoading.upload = false;
                }
            },

            // 单文件上传
            async uploadCodeSingle() {
                let successCount = 0;
                let failCount = 0;
                let errorMessages = [];
                
                for (let fileItem of this.codeFileList) {
                    try {
                        const formData = new FormData();
                        formData.append('repositoryId', this.uploadForm.repositoryId);
                        formData.append('branchName', this.uploadForm.branchName);
                        formData.append('file', fileItem.raw);
                        formData.append('fileName', fileItem.name);
                        formData.append('commitMessage', this.uploadForm.commitMessage || `上传文件: ${fileItem.name}`);
                        
                        const response = await this.codeRequestFormData('POST', '/api/code/commit', formData);
                        
                        if (response.code === 200) {
                            successCount++;
                        } else {
                            failCount++;
                            const errorMsg = response.message || '上传失败';
                            errorMessages.push(`${fileItem.name}: ${errorMsg}`);
                            console.error(`上传 ${fileItem.name} 失败:`, response.message);
                        }
                    } catch (error) {
                        failCount++;
                        const errorMsg = error.message || '上传异常';
                        errorMessages.push(`${fileItem.name}: ${errorMsg}`);
                        console.error(`上传 ${fileItem.name} 异常:`, error);
                    }
                }
                
                this.handleUploadResult(successCount, failCount, errorMessages);
            },

            // 批量上传
            async uploadCodeBatch() {
                try {
                    const formData = new FormData();
                    formData.append('repositoryId', this.uploadForm.repositoryId);
                    formData.append('branchName', this.uploadForm.branchName);
                    formData.append('commitMessage', this.uploadForm.commitMessage);
                    
                    // 添加所有文件
                    for (let fileItem of this.codeFileList) {
                        formData.append('files', fileItem.raw);
                    }
                    
                    const response = await this.codeRequestFormData('POST', '/api/code/commit-batch', formData);
                    
                    if (response.code === 200) {
                        this.$message.success(`批量提交成功：${this.codeFileList.length} 个文件`);
                        this.clearCodeFiles();
                        this.uploadForm.commitMessage = '';
                        this.loadEvidenceList();
                        this.loadStats();
                    } else {
                        this.$message.error(response.message || '批量提交失败');
                    }
                } catch (error) {
                    console.error('批量上传异常:', error);
                    this.$message.error('批量提交失败：' + error.message);
                    throw error;
                }
            },

            // 处理上传结果
            handleUploadResult(successCount, failCount, errorMessages = []) {
                // 显示上传结果
                if (successCount > 0 && failCount === 0) {
                    this.$message.success(`成功上传 ${successCount} 个文件`);
                } else if (successCount > 0 && failCount > 0) {
                    this.$message.warning(`成功上传 ${successCount} 个文件，${failCount} 个文件上传失败`);
                } else {
                    // 如果有具体的错误信息，显示第一个错误
                    if (errorMessages.length > 0) {
                        // 检查是否所有错误都是相同的（如哈希值重复）
                        const firstError = errorMessages[0];
                        const isAllSameError = errorMessages.every(msg => msg.includes(firstError.split(': ')[1]));
                        
                        if (isAllSameError && firstError.includes('哈希值已存在')) {
                            this.$message.error('哈希值已存在，不可重复上传！');
                        } else {
                            // 显示具体的错误信息
                            const errorMsg = errorMessages.length === 1 
                                ? errorMessages[0] 
                                : `${errorMessages.length} 个文件上传失败：${errorMessages[0]}`;
                            this.$message.error(errorMsg);
                        }
                    } else {
                        this.$message.error(`所有文件上传失败`);
                    }
                }
                
                if (successCount > 0) {
                    this.clearCodeFiles();
                    this.uploadForm.commitMessage = '';
                    this.loadEvidenceList();
                    this.loadStats();
                }
            },

            // 合并分支
            async mergeBranch() {
                if (!this.selectedRepository || !this.mergeForm.sourceBranch || !this.mergeForm.targetBranch) {
                    this.$message.error('请选择仓库和分支');
                    return;
                }
                
                if (this.mergeForm.sourceBranch === this.mergeForm.targetBranch) {
                    this.$message.error('源分支和目标分支不能相同');
                    return;
                }
                
                // 确认合并操作
                try {
                    await this.$confirm(
                        `确认将分支 "${this.mergeForm.sourceBranch}" 合并到 "${this.mergeForm.targetBranch}" 吗？`,
                        '分支合并确认',
                        {
                            type: 'warning',
                            confirmButtonText: '确认合并',
                            cancelButtonText: '取消'
                        }
                    );
                } catch {
                    return; // 用户取消
                }
                
                this.codeLoading.merge = true;
                try {
                    const params = {
                        repositoryId: this.selectedRepository,
                        sourceBranch: this.mergeForm.sourceBranch,
                        targetBranch: this.mergeForm.targetBranch
                    };
                    
                    const response = await this.codeRequest('POST', '/api/code/merge', params);
                    if (response.code === 200) {
                        this.$message.success(`分支合并成功：${this.mergeForm.sourceBranch} → ${this.mergeForm.targetBranch}`);
                        this.mergeForm = { sourceBranch: '', targetBranch: '' };
                        this.loadBranches();
                        this.loadEvidenceList();
                        this.loadStats();
                    } else {
                        this.$message.error(response.message || '分支合并失败');
                    }
                } catch (error) {
                    console.error('合并分支失败:', error);
                    this.$message.error('合并失败：' + error.message);
                } finally {
                    this.codeLoading.merge = false;
                }
            },
            
            // 加载仓库列表
            async loadRepositories() {
                if (!this.userInfo) {
                    console.log('用户未登录，无法加载仓库数据');
                    return;
                }
                
                try {
                    console.log('开始加载仓库列表...');
                    
                    // 使用axios而不是codeRequest
                    const response = await axios.get('/api/code/repositories');
                    console.log('仓库列表API响应:', response);
                    
                    // response已经是由axios拦截器处理后的data部分
                    this.repositories = response || [];
                    console.log('设置repositories数据:', this.repositories);
                    console.log('repositories数组长度:', this.repositories.length);
                    
                    // 强制触发Vue更新
                    this.$nextTick(() => {
                        this.$forceUpdate();
                    });
                    
                } catch (error) {
                    console.error('加载仓库列表失败:', error);
                    this.repositories = [];
                    this.$message.error('加载仓库列表失败：' + error.message);
                }
            },
            
            // 加载分支列表
            async loadBranches() {
                if (!this.selectedRepository) {
                    this.branches = [];
                    return;
                }
                
                try {
                    const response = await this.codeRequest('GET', `/api/code/branches?repositoryId=${this.selectedRepository}`);
                    if (response.code === 200) {
                        this.branches = response.data || [];
                        // 如果没有选中分支且有分支列表，默认选中main分支
                        if (!this.uploadForm.branchName && this.branches.length > 0) {
                            const mainBranch = this.branches.find(b => b.branchName === 'main');
                            this.uploadForm.branchName = mainBranch ? 'main' : this.branches[0].branchName;
                        }
                    }
                } catch (error) {
                    console.error('加载分支列表失败:', error);
                }
            },
            
            // 加载代码存证记录
            async loadCodeEvidenceList() {
                if (!this.userInfo) {
                    console.log('用户未登录，无法加载代码存证数据');
                    return;
                }
                
                this.codeLoading.table = true;
                try {
                    console.log('开始加载代码存证记录...');
                    
                    // 直接使用axios而不是codeRequest，保证与axios拦截器一致
                    const response = await axios.get('/api/code/evidence');
                    console.log('代码存证API响应:', response);
                    
                    // response已经是由axios拦截器处理后的data部分
                    this.codeEvidenceList = response || [];
                    console.log('加载代码存证记录成功:', this.codeEvidenceList.length, '条');
                    console.log('代码存证数据:', this.codeEvidenceList);
                    
                    // 强制触发Vue更新
                    this.$nextTick(() => {
                        this.$forceUpdate();
                    });
                    
                } catch (error) {
                    console.error('加载代码存证记录失败:', error);
                    this.codeEvidenceList = [];
                    this.$message.error('加载代码存证记录失败，请检查网络连接');
                } finally {
                    this.codeLoading.table = false;
                }
            },
            
            // 加载统计信息
            async loadStats() {
                // 模拟统计数据，实际应该从后端获取
                this.stats = {
                    totalRepositories: this.repositories.length,
                    totalBranches: this.branches.length,
                    totalCommits: this.codeEvidenceList.length,
                    todayCommits: this.codeEvidenceList.filter(item => {
                        const today = new Date().toDateString();
                        const itemDate = new Date(item.createdAt).toDateString();
                        return today === itemDate;
                    }).length
                };
                console.log('代码存证统计信息:', this.stats);
            },
            
            // 仓库变更
            onRepositoryChange() {
                this.uploadForm.repositoryId = this.selectedRepository;
                this.loadBranches();
            },
            
            // 代码文件选择
            handleCodeFileSelect(file, fileList) {
                this.codeFileList = fileList;
            },
            
            // 代码文件拖拽处理
            handleCodeDrop(e) {
                e.preventDefault();
                this.isDragOver = false;
                
                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    for (let i = 0; i < files.length; i++) {
                        const file = files[i];
                        // 检查文件类型
                        const validExtensions = ['.py', '.java', '.js', '.ts', '.html', '.css', '.sql', '.json', '.xml', '.c', '.cpp', '.h', '.hpp', '.go', '.rs', '.php', '.rb', '.swift', '.kt', '.scala', '.sol'];
                        const fileExt = '.' + file.name.split('.').pop().toLowerCase();
                        
                        if (validExtensions.includes(fileExt)) {
                            this.codeFileList.push({
                                name: file.name,
                                size: file.size,
                                raw: file,
                                status: 'ready'
                            });
                        } else {
                            this.$message.warning(`不支持的文件类型: ${file.name}`);
                        }
                    }
                }
            },
            
            handleCodeDragOver(e) {
                e.preventDefault();
                this.isDragOver = true;
            },
            
            handleCodeDragLeave(e) {
                e.preventDefault();
                this.isDragOver = false;
            },
            
            // 清空代码文件
            clearCodeFiles() {
                this.codeFileList = [];
                if (this.$refs.codeUpload) {
                    this.$refs.codeUpload.clearFiles();
                }
            },
            
            // 代码存证详情查看
            viewCodeDetails(row) {
                this.$alert(`
                    <div style="text-align: left;">
                        <p><strong>文件名：</strong>${row.fileName}</p>
                        <p><strong>文件哈希：</strong>${row.fileHash}</p>
                        <p><strong>仓库：</strong>${row.gitGroupName}/${row.gitProjectName}</p>
                        <p><strong>分支：</strong>${row.gitBranchName}</p>
                        <p><strong>提交哈希：</strong>${row.gitCommitHash || '-'}</p>
                        <p><strong>提交信息：</strong>${row.gitCommitMessage || '-'}</p>
                        <p><strong>作者：</strong>${row.gitAuthorName || '-'}</p>
                        <p><strong>存证时间：</strong>${row.createdAt}</p>
                        <p><strong>区块号：</strong>${row.blockNumber || '-'}</p>
                        <p><strong>交易哈希：</strong>${row.transactionHash || '-'}</p>
                    </div>
                `, '存证详情', {
                    dangerouslyUseHTMLString: true,
                    customClass: 'evidence-detail-dialog'
                });
            },
            
            // 下载代码
            downloadCode(row) {
                this.$message.info('下载功能开发中...');
            },
            
            // 获取链上状态类型
            getChainStatusType(status) {
                switch (status) {
                    case 0: return 'warning'; // 待上链
                    case 1: return 'success'; // 已上链
                    case 2: return 'danger';  // 失败
                    default: return 'info';
                }
            },
            
            // 获取链上状态文本
            getChainStatusText(status) {
                switch (status) {
                    case 0: return '待上链';
                    case 1: return '已上链';
                    case 2: return '失败';
                    default: return '未知';
                }
            },
            
            // 代码存证HTTP请求封装
            async codeRequest(method, url, data = null) {
                const options = {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json',
                    },
                };
                
                // 添加认证头（如果有token）
                const token = localStorage.getItem('token');
                if (token) {
                    options.headers['Authorization'] = `Bearer ${token}`;
                }
                
                console.log(`发起${method}请求:`, url, options);
                
                // 处理GET请求参数
                if (method === 'GET' && data) {
                    const params = new URLSearchParams(data);
                    url += '?' + params.toString();
                } else if (data) {
                    // POST/PUT请求，将数据放在body中
                    if (method === 'POST' && url.includes('repository')) {
                        // 仓库创建使用FormData
                        const formData = new FormData();
                        Object.keys(data).forEach(key => {
                            if (data[key] !== null && data[key] !== undefined) {
                                formData.append(key, data[key]);
                            }
                        });
                        options.body = formData;
                        delete options.headers['Content-Type']; // 让浏览器自动设置Content-Type
                    } else if (method === 'POST' && url.includes('branch')) {
                        // 分支创建使用FormData
                        const formData = new FormData();
                        Object.keys(data).forEach(key => {
                            if (data[key] !== null && data[key] !== undefined) {
                                formData.append(key, data[key]);
                            }
                        });
                        options.body = formData;
                        delete options.headers['Content-Type'];
                    } else if (method === 'POST' && url.includes('merge')) {
                        // 分支合并使用FormData
                        const formData = new FormData();
                        Object.keys(data).forEach(key => {
                            if (data[key] !== null && data[key] !== undefined) {
                                formData.append(key, data[key]);
                            }
                        });
                        options.body = formData;
                        delete options.headers['Content-Type'];
                    } else {
                        options.body = JSON.stringify(data);
                    }
                }
                
                const response = await fetch(url, options);
                console.log(`${method}请求响应状态:`, response.status, response.statusText);
                
                const jsonResponse = await response.json();
                console.log(`${method}请求响应数据:`, jsonResponse);
                
                // 检查业务错误
                if (jsonResponse.code && jsonResponse.code !== 200) {
                    throw new Error(jsonResponse.message || '操作失败');
                }
                
                // 检查HTTP错误
                if (!response.ok) {
                    throw new Error(jsonResponse.message || `HTTP ${response.status}: ${response.statusText}`);
                }
                
                return jsonResponse;
            },
            
            // FormData请求封装
            async codeRequestFormData(method, url, formData) {
                const options = {
                    method: method,
                    body: formData
                };
                
                // 添加认证头（如果有token）
                const token = localStorage.getItem('token');
                if (token) {
                    options.headers = {
                        'Authorization': `Bearer ${token}`
                    };
                }
                
                const response = await fetch(url, options);
                const jsonResponse = await response.json();
                
                // 检查业务错误
                if (jsonResponse.code && jsonResponse.code !== 200) {
                    throw new Error(jsonResponse.message || '操作失败');
                }
                
                // 检查HTTP错误
                if (!response.ok) {
                    throw new Error(jsonResponse.message || `HTTP ${response.status}: ${response.statusText}`);
                }
                
                return jsonResponse;
            },

            // ==================== 文件存证管理相关方法 ====================
            
            // 加载文件存证初始数据
            async loadFileEvidenceInitialData() {
                try {
                    await Promise.all([
                        this.loadUserGroups(),
                        this.loadFileEvidenceStats()
                    ]);
                } catch (error) {
                    console.error('加载文件存证初始数据失败:', error);
                }
            },
            
            // 视图切换处理
            handleFileEvidenceViewChange(view) {
                this.fileEvidenceActiveView = view;
                
                switch(view) {
                    case 'groups':
                        this.loadGroupList();
                        break;
                    case 'projects':
                        this.loadProjectList();
                        break;
                    case 'files':
                        this.loadFileEvidenceList();
                        break;
                    case 'logs':
                        this.loadOperationLogs();
                        break;
                }
            },
            
            // 分组管理相关方法
            async loadUserGroups() {
                try {
                    const response = await axios.get('/api/file-evidence-management/groups');
                    this.userGroups = response || [];
                } catch (error) {
                    console.error('加载用户分组失败:', error);
                    this.userGroups = [];
                }
            },
            
            async loadGroupList() {
                this.groupListLoading = true;
                try {
                    const params = {
                        current: this.groupPagination.current,
                        size: this.groupPagination.size
                    };
                    if (this.groupSearchKeyword) {
                        params.searchKeyword = this.groupSearchKeyword;
                    }
                    
                    const response = await axios.get('/api/file-evidence-management/groups/page', { params });
                    this.groupList = response.records || [];
                    this.groupPagination.total = response.total || 0;
                } catch (error) {
                    console.error('加载分组列表失败:', error);
                    this.$message.error('加载分组列表失败');
                } finally {
                    this.groupListLoading = false;
                }
            },
            
            showCreateGroupDialog() {
                this.createGroupDialogVisible = true;
                this.createGroupForm = {
                    groupName: '',
                    groupCode: '',
                    description: ''
                };
            },
            
            handleCreateGroupClose() {
                this.createGroupDialogVisible = false;
                this.$refs.createGroupForm?.resetFields();
            },
            
            onGroupNameChange() {
                if (this.createGroupForm.groupName && !this.createGroupForm.groupCode) {
                    this.generateGroupCode();
                }
            },
            
            async generateGroupCode() {
                if (!this.createGroupForm.groupName) {
                    this.$message.warning('请先输入分组名称');
                    return;
                }
                try {
                    const response = await axios.get('/api/file-evidence-management/code-generate/group', {
                        params: { groupName: this.createGroupForm.groupName }
                    });
                    this.createGroupForm.groupCode = response;
                } catch (error) {
                    console.error('生成分组代码失败:', error);
                }
            },
            
            async handleCreateGroup() {
                if (!this.$refs.createGroupForm) return;
                
                this.$refs.createGroupForm.validate(async (valid) => {
                    if (!valid) return;
                    
                    this.createGroupLoading = true;
                    try {
                        await axios.post('/api/file-evidence-management/groups', this.createGroupForm);
                        this.$message.success('分组创建成功');
                        this.createGroupDialogVisible = false;
                        await this.loadUserGroups();
                        await this.loadGroupList();
                    } catch (error) {
                        console.error('创建分组失败:', error);
                        this.$message.error(error.message || '创建分组失败');
                    } finally {
                        this.createGroupLoading = false;
                    }
                });
            },
            
            editGroup(group) {
                this.editGroupForm = {
                    id: group.id,
                    groupName: group.groupName,
                    groupCode: group.groupCode,
                    description: group.description
                };
                this.editGroupDialogVisible = true;
            },
            
            async handleEditGroup() {
                if (!this.$refs.editGroupForm) return;
                
                this.$refs.editGroupForm.validate(async (valid) => {
                    if (!valid) return;
                    
                    this.editGroupLoading = true;
                    try {
                        await axios.put(`/api/file-evidence-management/groups/${this.editGroupForm.id}`, {
                            groupName: this.editGroupForm.groupName,
                            description: this.editGroupForm.description
                        });
                        this.$message.success('分组更新成功');
                        this.editGroupDialogVisible = false;
                        await this.loadUserGroups();
                        await this.loadGroupList();
                    } catch (error) {
                        console.error('更新分组失败:', error);
                        this.$message.error(error.message || '更新分组失败');
                    } finally {
                        this.editGroupLoading = false;
                    }
                });
            },
            
            async toggleGroupStatus(group) {
                const action = group.status === 1 ? 'disable' : 'enable';
                const actionText = group.status === 1 ? '禁用' : '启用';
                
                try {
                    await this.$confirm(`确定要${actionText}分组"${group.groupName}"吗？`, '提示', {
                        type: 'warning'
                    });
                    
                    await axios.put(`/api/file-evidence-management/groups/${group.id}/${action}`);
                    this.$message.success(`分组${actionText}成功`);
                    await this.loadGroupList();
                } catch (error) {
                    if (error !== 'cancel') {
                        console.error(`${actionText}分组失败:`, error);
                        this.$message.error(`${actionText}分组失败`);
                    }
                }
            },
            
            // 项目管理相关方法
            async loadProjectList() {
                this.projectListLoading = true;
                try {
                    const params = {
                        current: this.projectPagination.current,
                        size: this.projectPagination.size
                    };
                    if (this.projectFilterGroupId) {
                        params.groupId = this.projectFilterGroupId;
                    }
                    if (this.projectSearchKeyword) {
                        params.searchKeyword = this.projectSearchKeyword;
                    }
                    
                    const response = await axios.get('/api/file-evidence-management/projects/page', { params });
                    this.projectList = response.records || [];
                    this.projectPagination.total = response.total || 0;
                } catch (error) {
                    console.error('加载项目列表失败:', error);
                    this.$message.error('加载项目列表失败');
                } finally {
                    this.projectListLoading = false;
                }
            },
            
            showCreateProjectDialog() {
                if (this.userGroups.length === 0) {
                    this.$message.warning('请先创建分组');
                    return;
                }
                this.createProjectDialogVisible = true;
                this.createProjectForm = {
                    groupId: null,
                    projectName: '',
                    projectCode: '',
                    description: ''
                };
            },
            
            handleCreateProjectClose() {
                this.createProjectDialogVisible = false;
                this.$refs.createProjectForm?.resetFields();
            },
            
            onProjectNameChange() {
                if (this.createProjectForm.projectName && !this.createProjectForm.projectCode) {
                    this.generateProjectCode();
                }
            },
            
            async generateProjectCode() {
                if (!this.createProjectForm.projectName) {
                    this.$message.warning('请先输入项目名称');
                    return;
                }
                try {
                    const response = await axios.get('/api/file-evidence-management/code-generate/project', {
                        params: { projectName: this.createProjectForm.projectName }
                    });
                    this.createProjectForm.projectCode = response;
                } catch (error) {
                    console.error('生成项目代码失败:', error);
                }
            },
            
            async handleCreateProject() {
                if (!this.$refs.createProjectForm) return;
                
                this.$refs.createProjectForm.validate(async (valid) => {
                    if (!valid) return;
                    
                    this.createProjectLoading = true;
                    try {
                        await axios.post('/api/file-evidence-management/projects', this.createProjectForm);
                        this.$message.success('项目创建成功');
                        this.createProjectDialogVisible = false;
                        await this.loadUserProjects();
                        await this.loadProjectList();
                    } catch (error) {
                        console.error('创建项目失败:', error);
                        this.$message.error(error.message || '创建项目失败');
                    } finally {
                        this.createProjectLoading = false;
                    }
                });
            },
            
            editProject(project) {
                this.editProjectForm = {
                    id: project.id,
                    projectName: project.projectName,
                    projectCode: project.projectCode,
                    description: project.description
                };
                this.editProjectDialogVisible = true;
            },
            
            async handleEditProject() {
                if (!this.$refs.editProjectForm) return;
                
                this.$refs.editProjectForm.validate(async (valid) => {
                    if (!valid) return;
                    
                    this.editProjectLoading = true;
                    try {
                        await axios.put(`/api/file-evidence-management/projects/${this.editProjectForm.id}`, {
                            projectName: this.editProjectForm.projectName,
                            description: this.editProjectForm.description
                        });
                        this.$message.success('项目更新成功');
                        this.editProjectDialogVisible = false;
                        await this.loadUserProjects();
                        await this.loadProjectList();
                    } catch (error) {
                        console.error('更新项目失败:', error);
                        this.$message.error(error.message || '更新项目失败');
                    } finally {
                        this.editProjectLoading = false;
                    }
                });
            },
            
            async toggleProjectStatus(project) {
                const action = project.status === 1 ? 'disable' : 'enable';
                const actionText = project.status === 1 ? '禁用' : '启用';
                
                try {
                    await this.$confirm(`确定要${actionText}项目"${project.projectName}"吗？`, '提示', {
                        type: 'warning'
                    });
                    
                    await axios.put(`/api/file-evidence-management/projects/${project.id}/${action}`);
                    this.$message.success(`项目${actionText}成功`);
                    await this.loadProjectList();
                } catch (error) {
                    if (error !== 'cancel') {
                        console.error(`${actionText}项目失败:`, error);
                        this.$message.error(`${actionText}项目失败`);
                    }
                }
            },
            
            async loadUserProjects() {
                try {
                    const response = await axios.get('/api/file-evidence-management/projects');
                    this.userProjects = response || [];
                } catch (error) {
                    console.error('加载用户项目失败:', error);
                    this.userProjects = [];
                }
            },
            
            async onGroupChange(groupId) {
                this.selectedProjectId = null;
                if (groupId) {
                    try {
                        const response = await axios.get('/api/file-evidence-management/projects', {
                            params: { groupId }
                        });
                        this.currentProjects = response || [];
                    } catch (error) {
                        console.error('加载分组项目失败:', error);
                        this.currentProjects = [];
                    }
                } else {
                    this.currentProjects = [];
                }
            },
            
            // 文件上传相关方法
            beforeFileEvidenceUpload(file) {
                if (!this.selectedProjectId) {
                    this.$message.error('请先选择目标项目');
                    return false;
                }
                
                const isLt100M = file.size / 1024 / 1024 < 100;
                if (!isLt100M) {
                    this.$message.error('上传文件大小不能超过 100MB!');
                    return false;
                }
                
                return true;
            },
            
            beforeFileEvidenceBatchUpload(file) {
                return this.beforeFileEvidenceUpload(file);
            },
            
            async submitFileEvidenceUpload() {
                if (!this.selectedProjectId) {
                    this.$message.error('请选择目标项目');
                    return;
                }
                
                if (this.fileEvidenceFileList.length > 0) {
                    // 单文件上传
                    this.fileEvidenceUploadData = {
                        projectId: this.selectedProjectId,
                        hashAlgorithm: this.fileEvidenceHashAlgorithm,
                        description: this.fileEvidenceDescription
                    };
                    this.$refs.fileEvidenceUpload.submit();
                } else if (this.fileEvidenceBatchFileList.length > 0) {
                    // 批量上传
                    if (!this.batchCommitMessage) {
                        this.$message.error('批量上传请输入提交信息');
                        return;
                    }
                    this.fileEvidenceBatchUploadData = {
                        projectId: this.selectedProjectId,
                        hashAlgorithm: this.fileEvidenceHashAlgorithm,
                        commitMessage: this.batchCommitMessage
                    };
                    this.$refs.fileEvidenceBatchUpload.submit();
                } else {
                    this.$message.error('请选择要上传的文件');
                }
            },
            
            handleFileEvidenceUploadSuccess(response) {
                this.$message.success('文件上传成功');
                this.fileEvidenceFileList = [];
                this.fileEvidenceDescription = '';
                this.loadFileEvidenceStats();
            },
            
            handleFileEvidenceUploadError(error) {
                console.error('文件上传失败:', error);
                this.$message.error('文件上传失败');
            },
            
            handleFileEvidenceBatchUploadSuccess(response) {
                this.$message.success('批量文件上传成功');
                this.fileEvidenceBatchFileList = [];
                this.batchCommitMessage = '';
                this.loadFileEvidenceStats();
            },
            
            handleFileEvidenceBatchUploadError(error) {
                console.error('批量文件上传失败:', error);
                this.$message.error('批量文件上传失败');
            },
            
            // 文件列表相关方法
            async loadFileEvidenceList() {
                this.fileEvidenceListLoading = true;
                try {
                    const params = {
                        current: this.fileEvidencePagination.current,
                        size: this.fileEvidencePagination.size
                    };
                    if (this.fileFilterProjectId) {
                        params.projectId = this.fileFilterProjectId;
                    }
                    if (this.fileFilterGroupId) {
                        params.groupId = this.fileFilterGroupId;
                    }
                    if (this.fileSearchKeyword) {
                        params.fileName = this.fileSearchKeyword;
                    }
                    if (this.fileFilterTimeRange && this.fileFilterTimeRange.length === 2) {
                        params.startTime = this.fileFilterTimeRange[0];
                        params.endTime = this.fileFilterTimeRange[1];
                    }
                    
                    const response = await axios.get('/api/file-evidence/query', { params });
                    this.fileEvidenceList = response.records || [];
                    this.fileEvidencePagination.total = response.total || 0;
                } catch (error) {
                    console.error('加载文件列表失败:', error);
                    this.$message.error('加载文件列表失败');
                } finally {
                    this.fileEvidenceListLoading = false;
                }
            },
            
            viewFileEvidence(fileEvidence) {
                this.currentFileEvidence = fileEvidence;
                this.fileEvidenceDetailDialogVisible = true;
            },
            
            async verifyFileEvidence(fileHash) {
                try {
                    const result = await axios.get(`/api/file-evidence/verify/${fileHash}`);
                    if (result) {
                        this.$message.success('文件存证验证通过');
                    } else {
                        this.$message.warning('文件存证验证失败');
                    }
                } catch (error) {
                    console.error('验证文件存证失败:', error);
                    this.$message.error('验证文件存证失败');
                }
            },
            
            // 操作日志相关方法
            async loadOperationLogs() {
                this.operationLogListLoading = true;
                try {
                    const params = {
                        current: this.logPagination.current,
                        size: this.logPagination.size
                    };
                    if (this.logFilterOperationType) {
                        params.operationType = this.logFilterOperationType;
                    }
                    
                    const response = await axios.get('/api/file-evidence-management/operation-logs', { params });
                    this.operationLogList = response.records || [];
                    this.logPagination.total = response.total || 0;
                } catch (error) {
                    console.error('加载操作日志失败:', error);
                    this.$message.error('加载操作日志失败');
                } finally {
                    this.operationLogListLoading = false;
                }
            },
            
            // 统计信息相关方法
            async loadFileEvidenceStats() {
                try {
                    // 这里可以调用统计接口，暂时使用计算值
                    this.fileEvidenceStats = {
                        totalGroups: this.userGroups.length,
                        totalProjects: this.userProjects.length,
                        totalFiles: this.fileEvidenceList.length,
                        todayFiles: 0 // 可以通过接口获取
                    };
                } catch (error) {
                    console.error('加载文件存证统计失败:', error);
                }
            },
            
            // 分页处理方法
            handleGroupSizeChange(size) {
                this.groupPagination.size = size;
                this.groupPagination.current = 1;
                this.loadGroupList();
            },
            
            handleGroupCurrentChange(current) {
                this.groupPagination.current = current;
                this.loadGroupList();
            },
            
            handleProjectSizeChange(size) {
                this.projectPagination.size = size;
                this.projectPagination.current = 1;
                this.loadProjectList();
            },
            
            handleProjectCurrentChange(current) {
                this.projectPagination.current = current;
                this.loadProjectList();
            },
            
            handleFileEvidenceSizeChange(size) {
                this.fileEvidencePagination.size = size;
                this.fileEvidencePagination.current = 1;
                this.loadFileEvidenceList();
            },
            
            handleFileEvidenceCurrentChange(current) {
                this.fileEvidencePagination.current = current;
                this.loadFileEvidenceList();
            },
            
            resetFileSearch() {
                this.fileSearchKeyword = '';
                this.fileFilterProjectId = null;
                this.fileFilterGroupId = null;
                this.fileFilterTimeRange = null;
                this.fileEvidencePagination.current = 1;
                this.loadFileEvidenceList();
            },
            
            handleLogSizeChange(size) {
                this.logPagination.size = size;
                this.logPagination.current = 1;
                this.loadOperationLogs();
            },
            
            handleLogCurrentChange(current) {
                this.logPagination.current = current;
                this.loadOperationLogs();
            },
            
            // 辅助方法
            getChainStatusType(status) {
                const types = {
                    0: 'info',    // 待处理
                    1: 'success', // 成功
                    2: 'danger'   // 失败
                };
                return types[status] || 'info';
            },
            
            getChainStatusText(status) {
                const texts = {
                    0: '待上链',
                    1: '已上链',
                    2: '上链失败'
                };
                return texts[status] || '未知';
            },
            
            getOperationTypeTag(type) {
                const tags = {
                    'CREATE_GROUP': 'success',
                    'CREATE_PROJECT': 'success',
                    'UPLOAD_FILE': 'primary',
                    'BATCH_UPLOAD_FILE': 'warning'
                };
                return tags[type] || 'info';
            },
            
            getOperationTypeText(type) {
                const texts = {
                    'CREATE_GROUP': '创建分组',
                    'CREATE_PROJECT': '创建项目',
                    'UPLOAD_FILE': '上传文件',
                    'BATCH_UPLOAD_FILE': '批量上传'
                };
                return texts[type] || type;
            },
            
            formatDateTime(dateTime) {
                if (!dateTime) return '-';
                return new Date(dateTime).toLocaleString();
            },
            
            // ==================== 文件存证管理方法结束 ====================
            
            logout() {
                this.$confirm('确定要退出登录吗？', '提示', { type: 'warning' })
                    .then(() => {
                        localStorage.removeItem('token');
                        localStorage.removeItem('userInfo');
                        this.userInfo = null;
                        this.evidenceList = [];
                        this.recentUploads = [];
                        this.$message.success('已退出登录');
                    });
            }
        }
    });
</script>
</body>
</html>
